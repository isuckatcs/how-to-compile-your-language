// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n456\n'

fn main() {
  let p1 = gc(123);
  let p2 = gc(456);

  if p1 == p1 {
  // CHECK: %2 = load ptr, ptr %p1, align 8
  // CHECK-NEXT: %3 = load ptr, ptr %p1, align 8
  // CHECK-NEXT: %4 = icmp eq ptr %2, %3
    println(123);
  } else {
    println(456);
  }

  if p1 == p2 {
  // CHECK: %5 = load ptr, ptr %p1, align 8
  // CHECK-NEXT: %6 = load ptr, ptr %p2, align 8
  // CHECK-NEXT: %7 = icmp eq ptr %5, %6
    println(123);
  } else {
    println(456);
  }
}
