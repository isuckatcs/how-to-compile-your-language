// RUN: compiler %s 2>&1 -res-dump | filecheck %s
trait Foo {
  fn foo(self: Self) {}
  fn bar<T>() {}
  fn baz(x: number) {}
}

fn foo(x: *impl Foo) {}
// CHECK: FunctionDecl @({{.*}}) foo {(*impl Foo) -> unit}
// CHECK-NEXT:   ParamDecl @({{.*}}) x {*impl Foo}
// CHECK-NEXT:   Block

fn main() {}
