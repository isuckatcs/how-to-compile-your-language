// RUN: compiler %s 2>&1 -res-dump | filecheck %s
trait A {}

trait B : A {}

trait C {}

struct S {
  x: *impl C,
  y: *impl B
}

fn foo(x: *impl B, y: *impl A) {
  S { 
    // CHECK: [[# @LINE + 1 ]]:8: error: cannot unify '*impl B' with '*impl C'
    x: x,
    
    // CHECK: [[# @LINE + 1 ]]:8: error: cannot unify '*impl A' with '*impl B'
    y: y,
  };
}

fn main() {}
