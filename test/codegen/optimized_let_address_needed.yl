// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
fn foo(x: borrowed number) {
  println(x);
}

fn main() {
  let x = 123;
  foo(x);
}
// CHECK: define void @__builtin_main(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %x = alloca double, align 8
// CHECK-NEXT:   store double 1.230000e+02, ptr %x, align 8
// CHECK-NEXT:   call void @foo(ptr %x, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
