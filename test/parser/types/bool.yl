// RUN: compiler %s -ast-dump 2>&1 | filecheck %s
fn main() {
  mut b: bool;

  b = true;
  b = false;
}
// CHECK: FunctionDecl: main
// CHECK-NEXT:   Block
// CHECK-NEXT:     DeclStmt:
// CHECK-NEXT:       VarDecl: b
// CHECK-NEXT:         BuiltinType: 
// CHECK-NEXT:     Assignment:
// CHECK-NEXT:       PathExpr:
// CHECK-NEXT:         DeclRefExpr: b
// CHECK-NEXT:       BoolLiteral: 'true'
// CHECK-NEXT:     Assignment:
// CHECK-NEXT:       PathExpr:
// CHECK-NEXT:         DeclRefExpr: b
// CHECK-NEXT:       BoolLiteral: 'false'
