// RUN: compiler %s 2>&1 -res-dump | filecheck %s
trait A {
  fn foo() {
    ->(){
      Self::foo;
      // CHECK: DeclRefExpr @({{.*}}) @<__Self impl A>::foo {() -> unit}
    };
  }
}

struct S {
  fn foo() {
    ->(){
      Self::foo;
      // CHECK: DeclRefExpr @({{.*}}) S::foo {() -> unit}
    };
  }
}

fn main() {}
