// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
struct S {
  n1: number,
  n2: number,
  n3: number,
  n4: number,
  n5: number,
  n6: number,
  n7: number,
  n8: number,
  n9: number,
  n10: number,
}

fn main() {
  gc(S {
    n1: 0,
    n2: 0,
    n3: 0,
    n4: 0,
    n5: 0,
    n6: 0,
    n7: 0,
    n8: 0,
    n9: 0,
    n10: 0,
  });
  // CHECK-NEXT: alloc @{{.*}}, data: {{.*}} (80 B) {heap: 104 B, threshold: 96 B}
  // CHECK-NEXT: [0] mark @{{.*}}, data: {{.*}} (80 B) {heap: 104 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {heap: 104 B, threshold: 208 B}

  gcCollect();
  // CHECK-NEXT: [1] sweep @{{.*}}, data: {{.*}} (80 B) {heap: 0 B, threshold: 208 B}
  // CHECK-NEXT: [1] sweep {heap: 0 B, threshold: 96 B}
}
