// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %valgrind %t

struct Empty {}

fn foo<T>(t: T) {}

fn main() {
  let x = gc(unit);
  // CHECK: %0 = call ptr @gcAlloc(i32 0, ptr null)
  // CHECK-NEXT: store ptr %0, ptr %tmp.root, align 8
  // CHECK-NEXT: store ptr %0, ptr %x, align 8
  // CHECK-NEXT: store ptr null, ptr %tmp.root, align 8
  
  foo(*x);
  // CHECK-NEXT: call void @_Y3fooGuE()

  let y = gc(Empty{});
  // CHECK-NEXT: %1 = call ptr @gcAlloc(i32 0, ptr null)
  // CHECK-NEXT: store ptr %1, ptr %tmp.root, align 8
  // CHECK-NEXT: store ptr %1, ptr %y, align 8
  // CHECK-NEXT: store ptr null, ptr %tmp.root, align 8
  
  foo(*y);
  // CHECK-NEXT: call void @_Y3fooGS5EmptyE()
}
