// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
fn alloc(): *number {
  return gc(456);
}

fn collect(ptr: *mut *number): *mut *number {
  gcCollect();
  return ptr;
}

fn main() {
  let p = gcMut(gc(123));
  // CHECK: alloc @{{.*}}, data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
  // CHECK-NEXT: alloc @{{.*}}, data: {{.*}} (8 B) offsets: {0 @(nil)} {heap: 64 B, threshold: 96 B}

  *collect(p) = alloc();
  // CHECK-NEXT: alloc @{{.*}}, data: {{.*}} (8 B) {heap: 96 B, threshold: 96 B}
  // CHECK-NEXT: [0] mark @{{.*}}, data: {{.*}} (8 B) {heap: 96 B, threshold: 96 B}
  // CHECK-NEXT: [0] mark @{{.*}}, data: {{.*}} (8 B) offsets: {0 @{{.*}}} {heap: 96 B, threshold: 96 B}
  // CHECK-NEXT: [0] mark @{{.*}}, data: {{.*}} (8 B) {heap: 96 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {heap: 96 B, threshold: 192 B}

  println(**p);
  // CHECK-NEXT: 456
}
