// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
fn main() {
  gc(123);
  // CHECK: [0] alloc {{.*}} data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
  
  gc(123);
  // CHECK-NEXT: [0] alloc {{.*}} data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
  
  gc(123);
  // CHECK-NEXT: [0] alloc {{.*}} data: {{.*}} (8 B) {heap: 96 B, threshold: 96 B}
  
  gc(123);
  // CHECK-NEXT: [0] alloc {{.*}} data: {{.*}} (8 B) {heap: 128 B, threshold: 96 B}
  // CHECK-NEXT: [0] mark {{.*}} data: {{.*}} (8 B) {heap: 128 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {{.*}} data: {{.*}} (8 B) {heap: 96 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {{.*}} data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {{.*}} data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {heap: 32 B, threshold: 96 B}

  let x = gc(123);
  // CHECK-NEXT: [1] alloc {{.*}} data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}

  let y = gc(123);
  // CHECK-NEXT: [1] alloc {{.*}} data: {{.*}} (8 B) {heap: 96 B, threshold: 96 B}

  let z = gc(123);
  // CHECK-NEXT: [1] alloc {{.*}} data: {{.*}} (8 B) {heap: 128 B, threshold: 96 B}
  // CHECK-NEXT: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 128 B, threshold: 96 B}
  // CHECK-NEXT: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 128 B, threshold: 96 B}
  // CHECK-NEXT: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 128 B, threshold: 96 B}
  // CHECK-NEXT: [1] sweep {{.*}} data: {{.*}} (8 B) {heap: 96 B, threshold: 96 B}
  // CHECK-NEXT: [1] sweep {heap: 96 B, threshold: 192 B}

  let w = gc(123);
  // CHECK-NEXT: [2] alloc {{.*}} data: {{.*}} (8 B) {heap: 128 B, threshold: 192 B}
}
// CHECK-NEXT: [2] sweep {{.*}} data: {{.*}} (8 B) {heap: 96 B, threshold: 192 B}
// CHECK-NEXT: [2] sweep {{.*}} data: {{.*}} (8 B) {heap: 64 B, threshold: 192 B}
// CHECK-NEXT: [2] sweep {{.*}} data: {{.*}} (8 B) {heap: 32 B, threshold: 192 B}
// CHECK-NEXT: [2] sweep {{.*}} data: {{.*}} (8 B) {heap: 0 B, threshold: 192 B}
// CHECK-NEXT: [2] sweep {heap: 0 B, threshold: 96 B}
