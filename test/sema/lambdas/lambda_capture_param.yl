// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn foo(x: number, y: number) {
  ->(){ x + y; };
  // CHECK: LambdaExpr {() -> unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) x {number}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) y {number}
  // CHECK-NEXT:   StructDecl @({{.*}}) (lambda@<source>:3:3) {(lambda@<source>:3:3)}
  // CHECK-NEXT:     FunctionDecl @({{.*}}) __builtin_lambda_call {(*(lambda@<source>:3:3)) -> unit}
}

fn main() {}
