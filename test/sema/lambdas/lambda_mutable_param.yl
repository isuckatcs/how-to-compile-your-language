// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn main() {
  ->(mut x: number) { x = 1; };
  // CHECK: LambdaExpr {(number) -> unit}
  // CHECK-NEXT:   StructDecl @({{.*}}) (closure@<source>:3:3) {(closure@<source>:3:3)}
  // CHECK-NEXT:     FunctionDecl @({{.*}}) __builtin_lambda_call {(number, *(closure@<source>:3:3)) -> unit}
  // CHECK-NEXT:       ParamDecl @({{.*}}) x {number}
  // CHECK-NEXT:       ParamDecl @({{.*}}) closure {*(closure@<source>:3:3)}
  // CHECK-NEXT:       Block
  // CHECK-NEXT:         Assignment
  // CHECK-NEXT:           DeclRefExpr @({{.*}}) x {number}
  // CHECK-NEXT:           NumberLiteral '1' {number}
  // CHECK-NEXT:           | value: 1
}
