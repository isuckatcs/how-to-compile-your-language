// RUN: compiler %s -res-dump 2>&1 | filecheck %s
fn foo(): bool {
    let x: number = 2.1;
    let y: number = 5.3;

    return (10.0 * (x + 4.0)) > 0 && (!(y == x) || x < y);
}
// CHECK: ReturnStmt
// CHECK-NEXT:   BinaryOperator '&&' {bool}
// CHECK-NEXT:   | value: true

fn bar(): number {
    let x: number = 2.1;

    return (x);
}
// CHECK: ReturnStmt
// CHECK-NEXT:   GroupingExpr {number}
// CHECK-NEXT:   | value: 2.1
// CHECK-NEXT:     PathExpr {number}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) x {number}

fn baz(x: number) {
    let y = (x);
    // CHECK: DeclStmt
    // CHECK-NEXT:   VarDecl @({{.*}}) y {number}
    // CHECK-NEXT:     GroupingExpr {number}
    // CHECK-NEXT:       PathExpr {number}
    // CHECK-NEXT:         DeclRefExpr @({{.*}}) x {number}
}

fn main(): unit {}
