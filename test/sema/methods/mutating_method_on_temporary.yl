// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {
  fn foo(self: &mut Self) {}
}

fn main() {
  S{}.foo();
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) S::foo {(&mut S) -> unit}
  // CHECK-NEXT:   UnaryOperator '&' {&mut S}
  // CHECK-NEXT:     MaterializeTemporaryExpr {S}
  // CHECK-NEXT:       StructInstantiationExpr {S}
  // CHECK-NEXT:         DeclRefExpr @({{.*}}) S {S}
}
