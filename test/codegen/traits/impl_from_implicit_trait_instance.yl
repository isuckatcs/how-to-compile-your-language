// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
trait A<T> {
  fn foo(self: Self);
}

struct S<T> {
  impl A<T> {
    fn foo(self: Self) {
      println(123);
    }
  }
}

fn main() {
  let s = S@<number>{};
  s.foo();
}
// CHECK: define void @__builtin_main(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YT1AGnE3fooGS1SGnEE(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
