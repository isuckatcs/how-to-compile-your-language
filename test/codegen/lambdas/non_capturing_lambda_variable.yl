// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n456\n'
struct S {
  x: unit,
  y: unit,
  z: unit,
}

fn main() {
// CHECK: define void @__builtin_main() gc "shadow-stack" {
  // CHECK: %lambda.tmp = alloca { ptr, ptr }, align 8
  // CHECK-NEXT: %l = alloca { ptr, ptr }, align 8

  // CHECK-NEXT: store { ptr, ptr } zeroinitializer, ptr %lambda.tmp, align 8
  // CHECK-NEXT: call void @llvm.gcroot(ptr %lambda.tmp, ptr @function.offsets)
  // CHECK-NEXT: store { ptr, ptr } zeroinitializer, ptr %l, align 8
  // CHECK-NEXT: call void @llvm.gcroot(ptr %l, ptr @function.offsets)

  let u = unit;

  let s = S { x: unit, y: unit, z: println(123) };
  // CHECK-NEXT: call void @println(double 1.230000e+02)

  let l = ->() {
    let capture1 = u;
    let capture2 = s;

    println(456);
  };
  // CHECK-NEXT: %0 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 0
  // CHECK-NEXT: store ptr @_YS8lambda_021__builtin_lambda_call, ptr %0, align 8
  // CHECK-NEXT: %1 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 1
  // CHECK-NEXT: store ptr null, ptr %1, align 8
  // CHECK-NEXT: call void @llvm.memcpy.p0.p0.i64(ptr align 8 %l, ptr align 8 %lambda.tmp, i64 16, i1 false)

  l();
  // CHECK-NEXT: %2 = getelementptr inbounds nuw { ptr, ptr }, ptr %l, i32 0, i32 0
  // CHECK-NEXT: %3 = load ptr, ptr %2, align 8
  // CHECK-NEXT: %4 = getelementptr inbounds nuw { ptr, ptr }, ptr %l, i32 0, i32 1
  // CHECK-NEXT: %5 = load ptr, ptr %4, align 8
  // CHECK-NEXT: call void %3(ptr %5)
}

// CHECK: define void @_YS8lambda_021__builtin_lambda_call(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double 4.560000e+02)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
