// RUN: compiler %s -res-dump 2>&1 | filecheck %s
trait A {}

struct S {}

fn foo<T : A>(x: T) {}

fn bar<U : A>(x: U) {
  foo(x);
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   PathExpr
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) foo {(U) -> unit}
  // CHECK-NEXT:   PathExpr
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) x {U}
}

fn main() {}
