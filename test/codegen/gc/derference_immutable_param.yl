// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %valgrind %t | grep -Plzx '123\n'
fn foo(n: **number) {
  println(**n);
}
// CHECK: define void @foo(ptr %n) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %0 = load ptr, ptr %n, align 8
// CHECK-NEXT:   %1 = load double, ptr %0, align 8
// CHECK-NEXT:   call void @println(double %1)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn main(): unit {
  foo(gc(gc(123)));
}
