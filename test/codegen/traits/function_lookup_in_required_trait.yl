// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '492\n'
trait B {
  fn foo(self: borrowed mut Self);
}

trait A : B {
  fn getX(self: borrowed Self): number;
}

struct S {
  x: number

  impl A {
    fn getX(self: borrowed Self): number {
      return self.x;
    }
  }

  impl B {
    fn foo(self: borrowed mut Self) {
      self.x = self.x * 2;
    }
  }
}

fn bar<T : A>(mut t : T) {
  t.foo();

  T::foo(t);

  println(t.getX());
}
// CHECK: define void @_Y3barGS1SE(ptr byval({ double }) %t, ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YT1B3fooGS1SE(ptr %t, ptr null)
// CHECK-NEXT:   call void @_YT1B3fooGS1SE(ptr %t, ptr null)
// CHECK-NEXT:   %0 = call double @_YT1A4getXGS1SE(ptr %t, ptr null)
// CHECK-NEXT:   call void @println(double %0, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn main() {
  bar(S{x: 123});
}
