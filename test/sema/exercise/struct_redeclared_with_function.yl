// RUN: compiler %s -res-dump 2>&1 | filecheck %s
struct S {}
// CHECK: StructDecl @({{.*}}) S {S}

fn S() {}
// CHECK: FunctionDecl @({{.*}}) S {() -> unit}
// CHECK-NEXT:   Block

fn main() {
  let s = S;
}
// CHECK: FunctionDecl @({{.*}}) main {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     DeclStmt
// CHECK-NEXT:       VarDecl @({{.*}}) s {() -> unit}
// CHECK-NEXT:         PathExpr {() -> unit}
// CHECK-NEXT:           DeclRefExpr @({{.*}}) S {() -> unit}
