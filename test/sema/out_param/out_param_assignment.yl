// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {
  x: number
}

fn foo(n: borrowed mut number, s: borrowed mut S) {
// CHECK: FunctionDecl @({{.*}}) foo {(&mut number, &mut S) -> unit}
// CHECK-NEXT:   ParamDecl @({{.*}}) n {&mut number}
// CHECK-NEXT:   ParamDecl @({{.*}}) s {&mut S}
// CHECK-NEXT:   Block

  n = 1;
  // CHECK-NEXT: Assignment
  // CHECK-NEXT:   ImplicitDerefExpr {number}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) n {&mut number}
  // CHECK-NEXT:   NumberLiteral '1' {number}
  // CHECK-NEXT:   | value: 1


  s.x = 2;
  // CHECK-NEXT: Assignment
  // CHECK-NEXT:   MemberExpr @({{.*}}) x {number}
  // CHECK-NEXT:     ImplicitDerefExpr {S}
  // CHECK-NEXT:       DeclRefExpr @({{.*}}) s {&mut S}
  // CHECK-NEXT:   NumberLiteral '2' {number}
  // CHECK-NEXT:   | value: 2
}

fn main() {}
