// RUN: compiler %s -cfg-dump 2>&1 | filecheck %s --match-full-lines
fn main() {
    let x = 0;
    let y = 1;
    let z = 2;

    let l = ->(){ y + z + x; };
}
// CHECK: main:
// CHECK-NEXT: [2 (entry)]
// CHECK-NEXT:   preds: 
// CHECK-NEXT:   succs: 1 
// CHECK-NEXT: 
// CHECK-NEXT: [1]
// CHECK-NEXT:   preds: 2 
// CHECK-NEXT:   succs: 0 
// CHECK-NEXT:   1: 0
// CHECK-NEXT:   2: let x = [1.1]
// CHECK-NEXT:   3: 1
// CHECK-NEXT:   4: let y = [1.3]
// CHECK-NEXT:   5: 2
// CHECK-NEXT:   6: let z = [1.5]
// CHECK-NEXT:   7: y
// CHECK-NEXT:   8: z
// CHECK-NEXT:   9: x
// CHECK-NEXT:   10: ->[[1.7], [1.8], [1.9]](...){...}
// CHECK-NEXT:   11: let l = [1.10]
// CHECK-NEXT: 
// CHECK-NEXT: [0 (exit)]
// CHECK-NEXT:   preds: 1 
// CHECK-NEXT:   succs: 

fn nonCapturing() {
    let l = ->(){};
}
// CHECK: nonCapturing:
// CHECK-NEXT: [2 (entry)]
// CHECK-NEXT:   preds: 
// CHECK-NEXT:   succs: 1 
// CHECK-NEXT: 
// CHECK-NEXT: [1]
// CHECK-NEXT:   preds: 2 
// CHECK-NEXT:   succs: 0 
// CHECK-NEXT:   1: ->[](...){...}
// CHECK-NEXT:   2: let l = [1.1]
// CHECK-NEXT: 
// CHECK-NEXT: [0 (exit)]
// CHECK-NEXT:   preds: 1 
// CHECK-NEXT:   succs: 
