// RUN: compiler %s 2>&1 -res-dump | filecheck %s
trait A {
  fn foo(self: &Self, x: number) {}
}

trait B : A {}

fn foo(x: *mut impl B) {
  x.foo(123);
}
// CHECK: FunctionDecl @({{.*}}) foo {(*mut impl B) -> unit}
// CHECK-NEXT:   ParamDecl @({{.*}}) x {*mut impl B}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) @<impl B impl A>::foo {(&impl B, number) -> unit}
// CHECK-NEXT:       ImplicitCoerceExpr {&impl B}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) x {*mut impl B}
// CHECK-NEXT:       NumberLiteral '123' {number}
// CHECK-NEXT:       | value: 123

fn main() {}
