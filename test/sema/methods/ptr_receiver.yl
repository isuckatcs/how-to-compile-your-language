// RUN: compiler %s 2>&1 -res-dump | filecheck %s
trait Foo {
  fn foo(self: *Self) {}
  fn bar(self: *mut Self) {}
}

struct S {
  impl Foo;
}

fn main() {
  let s = gc(S{});
  let s2 = gcMut(S{});

  s.foo();
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) @<S impl Foo>::foo {(*S) -> unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) s {*S}

  s2.bar();
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) @<S impl Foo>::bar {(*mut S) -> unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) s2 {*mut S}
}
