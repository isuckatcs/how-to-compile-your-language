// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '0\n1\n1\n'
struct S {
  fn foo<U>(self: &Self, x: U) {
    println(0);
  }
}

struct S2<T> {
  fn foo<U>(x: U) {
    println(1);
  }
}

fn main() {
  mut s = S{};
  s.foo(unit);

  S2@<unit>::foo(unit);

  S2@<number>::foo(unit);
}
// CHECK: define void @__builtin_main(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %s = alloca {}, align 8
// CHECK-NEXT:   call void @_YS1S3fooGuE(ptr %s, ptr null)
// CHECK-NEXT:   call void @_YS2S2GuE3fooGuE(ptr null)
// CHECK-NEXT:   call void @_YS2S2GnE3fooGuE(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YS1S3fooGuE(ptr %self, ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double 0.000000e+00, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YS2S2GuE3fooGuE(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double 1.000000e+00, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YS2S2GnE3fooGuE(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double 1.000000e+00, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
