// RUN: compiler %s -res-dump 2>&1 | filecheck %s
trait A {
  fn foo() {}
}
// CHECK: TraitDecl @({{.*}}) A
// CHECK-NEXT:   FunctionDecl @({{.*}}) foo {() -> unit}
// CHECK-NEXT:     TypeParamDecl @({{.*}}) __Self {__Self}
// CHECK-NEXT:     Block

struct S {
  impl A {
    fn foo() {}
    // CHECK: FunctionDecl @({{.*}}) foo {() -> unit}
    // CHECK-NEXT: | implements 'foo' @({{.*}})
    // CHECK-NEXT:   Block
  }
}

fn main() {
  S::foo();
}
// CHECK: FunctionDecl @({{.*}}) main {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {() -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) S {S}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) A::foo {() -> unit}
