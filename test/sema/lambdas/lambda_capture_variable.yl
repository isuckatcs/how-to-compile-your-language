// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn main() {
  let x = 0;

  ->(){ return x + 1; };
  // CHECK: LambdaExpr {() -> number}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) x {number}
  // CHECK-NEXT:   StructDecl @({{.*}}) (closure@<source>:5:3) {(closure@<source>:5:3)}
  // CHECK-NEXT:     FunctionDecl @({{.*}}) __builtin_lambda_call {(*(closure@<source>:5:3)) -> number}
}
