// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '20\n'

fn wrapper<T>(x: T): T {
  return x;
}

fn foo<U>(x: (U) -> U, y: U): U {
  return x(y);
}

fn main(): unit {
  let x = foo(wrapper, 20);
  // CHECK: %2 = call double @_Y3fooGnE(ptr byval({ ptr, ptr }) %struct.arg.tmp, double 2.000000e+01, ptr null)

  println(x);
}

// CHECK: define double @_Y3fooGnE(ptr byval({ ptr, ptr }) %x, double %y, ptr %closure) {
// CHECK: define double @_Y7wrapperGnE(double %x, ptr %closure) {

// CHECK-NOT: {{define.*wrapper.*}}
