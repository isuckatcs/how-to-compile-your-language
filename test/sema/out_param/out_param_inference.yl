// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn foo<T>(x: borrowed T) {}

fn main() {
  let x = 1;
  foo(x);
}
// CHECK: CallExpr {unit}
// CHECK-NEXT:   DeclRefExpr @({{.*}}) foo {(&number) -> unit}
// CHECK-NEXT:   ImplicitBorrowExpr {&number}
// CHECK-NEXT:     DeclRefExpr @({{.*}}) x {number}
