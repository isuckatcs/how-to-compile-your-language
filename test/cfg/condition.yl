// CHECK-NEXT:   succs: 0 
// CHECK-NEXT:   1: true
// CHECK-NEXT:   2: false
// CHECK-NEXT:   3: [1.1] || [1.2]
// CHECK-NEXT:   4: 1
// CHECK-NEXT: 
// CHECK-NEXT: [0 (exit)]
// CHECK-NEXT:   preds: 1 
// CHECK-NEXT:   succs:

fn and(): unit {
    true && false;
    1.0;
}
