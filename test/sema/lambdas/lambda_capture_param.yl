// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn foo(x: number, y: number) {
  ->(){ x + y; };
  // CHECK: LambdaExpr {(lambda@<source>:3:3)}
  // CHECK-NEXT:   StructDecl @({{.*}}) (lambda@<source>:3:3) {(lambda@<source>:3:3)}
  // CHECK-NEXT:     FunctionDecl @({{.*}}) __builtin_lambda_call {((lambda@<source>:3:3)) -> unit}
  // CHECK-NEXT:       ParamDecl @({{.*}}) self {(lambda@<source>:3:3)}
  // CHECK-NEXT:       Block
  // CHECK-NEXT:         BinaryOperator '+' {number}
  // CHECK-NEXT:           MemberExpr @({{.*}}) x {number}
  // CHECK-NEXT:             DeclRefExpr @({{.*}}) self {(lambda@<source>:3:3)}
  // CHECK-NEXT:           MemberExpr @({{.*}}) y {number}
  // CHECK-NEXT:             DeclRefExpr @({{.*}}) self {(lambda@<source>:3:3)}
  // CHECK-NEXT:     FieldDecl @({{.*}}) x {number}
  // CHECK-NEXT:     FieldDecl @({{.*}}) y {number}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) x {number}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) y {number}
}

fn main() {}
