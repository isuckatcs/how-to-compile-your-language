// RUN: compiler %s 2>&1 -ast-dump | filecheck %s
fn main() {
  *&*&*&x;
  // CHECK: UnaryOperator: '*'
  // CHECK-NEXT:   UnaryOperator: '&'
  // CHECK-NEXT:     UnaryOperator: '*'
  // CHECK-NEXT:       UnaryOperator: '&'
  // CHECK-NEXT:         UnaryOperator: '*'
  // CHECK-NEXT:           UnaryOperator: '&'
  // CHECK-NEXT:             DeclRefExpr: x

  &&**x && &&x;
  // CHECK: BinaryOperator: '&&'
  // CHECK-NEXT:   UnaryOperator: '&'
  // CHECK-NEXT:     UnaryOperator: '&'
  // CHECK-NEXT:       UnaryOperator: '*'
  // CHECK-NEXT:         UnaryOperator: '*'
  // CHECK-NEXT:           DeclRefExpr: x
  // CHECK-NEXT:   UnaryOperator: '&'
  // CHECK-NEXT:     UnaryOperator: '&'
  // CHECK-NEXT:       DeclRefExpr: x

  &&?x;
  // CHECK: UnaryOperator: '&'
  // CHECK-NEXT:   UnaryOperator: '&?'
  // CHECK-NEXT:     DeclRefExpr: x
}
