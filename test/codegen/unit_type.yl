// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
fn foo(x: unit): unit {
  return println(123);
}
// CHECK: define void @foo(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double 1.230000e+02, ptr null)
// CHECK-NEXT:   br label %return
// CHECK-NEXT: 
// CHECK-NEXT: return:                                           ; preds = %entry
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn main() {
  let x = unit;

  let y = foo(x);
}
// CHECK: define void @__builtin_main(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @foo(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
