// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o lambda_function_generated_lazily && ./lambda_function_generated_lazily | grep -Plzx '123\n'
fn main() {
  let x = 0;

  let f = ->() { println(x); };
  // CHECK: %0 = getelementptr inbounds nuw { double }, ptr %closure.tmp, i32 0, i32 0
  // CHECK-NEXT: store double 0.000000e+00, ptr %0, align 8
  // CHECK-NEXT: call void @llvm.memcpy.p0.p0.i64(ptr align 8 %f, ptr align 8 %closure.tmp, i64 8, i1 false)

  let f2 = ->(x) { println(x); };

  f2(123);
  // CHECK-NEXT: call void @_YS8lambda_021__builtin_lambda_call(double 1.230000e+02)
}

// CHECK: define void @_YS8lambda_021__builtin_lambda_call(double %x) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double %x)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK-NOT: {{.*lambda_1.*}}
