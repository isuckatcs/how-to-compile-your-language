// RUN: compiler %s -res-dump 2>&1 | filecheck %s --match-full-lines
fn binaryLhsKnown(y: bool): bool {
    mut x: bool = true;

    return (false && y) || (true || x);
}
// CHECK: ReturnStmt
// CHECK-NEXT:   BinaryOperator '||' {bool}
// CHECK-NEXT:   | value: true

fn unaryNonConst(): bool {
    mut x: bool = true;

    return !x;
}
// CHECK: ReturnStmt
// CHECK-NEXT:   UnaryOperator '!' {bool}
// CHECK-NEXT:     PathExpr {bool}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) x {bool}

fn ret(): bool {
    return true;
}

fn call(): unit {
    if !ret() {
        return;
    }
}
// CHECK: IfStmt
// CHECK-NEXT:   UnaryOperator '!' {bool}
// CHECK-NEXT:     CallExpr {bool}
// CHECK-NEXT:       PathExpr {() -> bool}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) ret {() -> bool}
// CHECK-NEXT:   Block
// CHECK-NEXT:     ReturnStmt

fn lhsKnownRhsNot(y: bool): bool {
    return true && y;
}
// CHECK: ReturnStmt
// CHECK-NEXT:   BinaryOperator '&&' {bool}
// CHECK-NEXT:     BoolLiteral 'true' {bool}
// CHECK-NEXT:     PathExpr {bool}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) y {bool}

fn lhsUnknownRhsFalse(x: bool): bool {
    return x && false;
}
// CHECK: ReturnStmt
// CHECK-NEXT:   BinaryOperator '&&' {bool}
// CHECK-NEXT:     PathExpr {bool}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) x {bool}
// CHECK-NEXT:     BoolLiteral 'false' {bool}

fn lhsUnknownRhsTrue(x: bool): bool {
    return x || true;
}
// CHECK: ReturnStmt
// CHECK-NEXT:   BinaryOperator '||' {bool}
// CHECK-NEXT:     PathExpr {bool}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) x {bool}
// CHECK-NEXT:     BoolLiteral 'true' {bool}

fn lhsUnknownRhsFalseOr(x: bool): bool {
    return x || false;
}
// CHECK: ReturnStmt
// CHECK-NEXT:   BinaryOperator '||' {bool}
// CHECK-NEXT:     PathExpr {bool}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) x {bool}
// CHECK-NEXT:     BoolLiteral 'false' {bool}

fn main(): unit {}
