// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn swap<T>(x: borrowed mut T, y: borrowed mut T) {
  let tmp = x;
  x = y;
  y = tmp;
}

fn wrapper(x: borrowed mut number, y: borrowed mut number) {
  swap(x, y);
}
// CHECK: FunctionDecl @({{.*}}) wrapper {(borrowed mut number, borrowed mut number) -> unit}
// CHECK-NEXT:   ParamDecl @({{.*}}) x {borrowed mut number}
// CHECK-NEXT:   ParamDecl @({{.*}}) y {borrowed mut number}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) swap {(borrowed mut number, borrowed mut number) -> unit}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) x {borrowed mut number}
// CHECK-NEXT:       DeclRefExpr @({{.*}}) y {borrowed mut number}

fn main() {}
