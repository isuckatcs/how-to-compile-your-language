// RUN: compiler %s -res-dump 2>&1 | filecheck %s
fn main() {
  let n = gcMut(123);

  *n = 456;
  // CHECK: Assignment
  // CHECK-NEXT:   UnaryOperator '*' {number}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) n {*mut number}
  // CHECK-NEXT:   NumberLiteral '456' {number}
  // CHECK-NEXT:   | value: 456
}
