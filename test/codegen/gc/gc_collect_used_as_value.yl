// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
fn main() {
  let collect = gcCollect;
  // CHECK: %0 = getelementptr inbounds nuw { ptr, ptr }, ptr %collect, i32 0, i32 0
  // CHECK-NEXT: store ptr @gcCollect, ptr %0, align 8
  // CHECK-NEXT: %1 = getelementptr inbounds nuw { ptr, ptr }, ptr %collect, i32 0, i32 1
  // CHECK-NEXT: store ptr null, ptr %1, align 8

  let n = *gc(123);

  collect();
  // CHECK: %4 = getelementptr inbounds nuw { ptr, ptr }, ptr %collect, i32 0, i32 0
  // CHECK-NEXT: %5 = load ptr, ptr %4, align 8
  // CHECK-NEXT: %6 = getelementptr inbounds nuw { ptr, ptr }, ptr %collect, i32 0, i32 1
  // CHECK-NEXT: %7 = load ptr, ptr %6, align 8
  // CHECK-NEXT: call void %5(ptr %7

  println(n);
}
