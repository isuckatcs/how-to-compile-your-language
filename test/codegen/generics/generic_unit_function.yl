// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
fn wrapper<T>(x: (T) -> T, a: T) {
  x(a);
}

fn sideEffect(x: unit) {
  println(123);
}

fn main() {
  wrapper(sideEffect, unit);
}
// CHECK: define void @__builtin_main() {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %struct.arg.tmp = alloca { ptr, ptr }, align 8
// CHECK-NEXT:   %0 = getelementptr inbounds nuw { ptr, ptr }, ptr %struct.arg.tmp, i32 0, i32 0
// CHECK-NEXT:   store ptr @sideEffect, ptr %0, align 8
// CHECK-NEXT:   %1 = getelementptr inbounds nuw { ptr, ptr }, ptr %struct.arg.tmp, i32 0, i32 1
// CHECK-NEXT:   store ptr null, ptr %1, align 8
// CHECK-NEXT:   call void @_Y7wrapperGuE(ptr byval({ ptr, ptr }) %struct.arg.tmp)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_Y7wrapperGuE(ptr byval({ ptr, ptr }) %x) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %0 = getelementptr inbounds nuw { ptr, ptr }, ptr %x, i32 0, i32 0
// CHECK-NEXT:   %1 = load ptr, ptr %0, align 8
// CHECK-NEXT:   %2 = getelementptr inbounds nuw { ptr, ptr }, ptr %x, i32 0, i32 1
// CHECK-NEXT:   %3 = load ptr, ptr %2, align 8
// CHECK-NEXT:   call void %1(ptr %3)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
