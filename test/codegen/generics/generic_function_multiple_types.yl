// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '1\n2\n3\n'
struct S {
  x: number
}

fn wrapper<T>(x: T): T {
  return x;
}

fn returnOne(): number {
  return 1;
}

fn main(): unit {
// CHECK: define void @__builtin_main(ptr %closure) gc "shadow-stack" {
  // CHECK: store { ptr, ptr } zeroinitializer, ptr %struct.ret.tmp, align 8
  // CHECK-NEXT: call void @llvm.gcroot(ptr %struct.ret.tmp, ptr @function.offsets)

  let x = wrapper(returnOne)();
  // CHECK: call void @_Y7wrapperGFRnE(ptr sret({ ptr, ptr }) %struct.ret.tmp, ptr byval({ ptr, ptr }) %struct.arg.tmp, ptr null)
  // CHECK-NEXT: %2 = getelementptr inbounds nuw { ptr, ptr }, ptr %struct.ret.tmp, i32 0, i32 0
  // CHECK-NEXT: %3 = load ptr, ptr %2, align 8
  // CHECK-NEXT: %4 = getelementptr inbounds nuw { ptr, ptr }, ptr %struct.ret.tmp, i32 0, i32 1
  // CHECK-NEXT: %5 = load ptr, ptr %4, align 8
  // CHECK-NEXT: %6 = call double %3(ptr %5)
  // CHECK-NEXT: store double %6, ptr %x, align 8

  let y = wrapper(2);
  // CHECK: %7 = call double @_Y7wrapperGnE(double 2.000000e+00, ptr null)
  // CHECK-NEXT: store double %7, ptr %y, align 8

  let z = wrapper(S{ x: 3 }).x;
  // CHECK: call void @_Y7wrapperGS1SE(ptr sret({ double }) %struct.ret.tmp1, ptr byval({ double }) %struct.arg.tmp2, ptr null)
  // CHECK-NEXT: %9 = getelementptr inbounds nuw { double }, ptr %struct.ret.tmp1, i32 0, i32 0
  // CHECK-NEXT: %10 = load double, ptr %9, align 8
  // CHECK-NEXT: store double %10, ptr %z, align 8

  println(x);
  println(y);
  println(z);
}
// CHECK: define void @_Y7wrapperGFRnE(ptr sret({ ptr, ptr }) %ret, ptr byval({ ptr, ptr }) %x, ptr %closure) {
// CHECK: define double @_Y7wrapperGnE(double %x, ptr %closure) {
// CHECK: define void @_Y7wrapperGS1SE(ptr sret({ double }) %ret, ptr byval({ double }) %x, ptr %closure) {


// CHECK-NOT: {{define.*wrapper.*}}
