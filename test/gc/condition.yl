// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
fn collect() {
  gcCollect();
}

fn main() {
  // CHECK: [0] alloc {{.*}} data: {{.*}} (1 B) {heap: 25 B, threshold: 96 B}
  if *gc(true) {

    collect();
    // CHECK-NEXT: [0] sweep {{.*}} data: {{.*}} (1 B) {heap: 0 B, threshold: 96 B}
    // CHECK-NEXT: [0] sweep {heap: 0 B, threshold: 96 B}
  }

  // CHECK-NEXT: [1] alloc {{.*}} data: {{.*}} (1 B) {heap: 25 B, threshold: 96 B}
  if *gc(false) {

  } else {
    collect();
    // CHECK-NEXT: [1] sweep {{.*}} data: {{.*}} (1 B) {heap: 0 B, threshold: 96 B}
    // CHECK-NEXT: [1] sweep {heap: 0 B, threshold: 96 B}
  }
}
