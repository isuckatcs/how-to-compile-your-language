// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
struct S {
  fn foo(x: number) {
    println(x);
  }
}

fn main() {
  let f = ->(x: number) {
    let f = S::foo;
    f(x);
  };
  // CHECK: %0 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 0
  // CHECK-NEXT: store ptr @_YS8lambda_021__builtin_lambda_call, ptr %0, align 8
  // CHECK-NEXT: %1 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 1
  // CHECK-NEXT: store ptr null, ptr %1, align 8

  f(123);
  // CHECK: call void %3(double 1.230000e+02, ptr %5)
}

// CHECK: define void @_YS8lambda_021__builtin_lambda_call(double %x, ptr %closure) gc "shadow-stack" {
