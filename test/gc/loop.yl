// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
fn collect() {
  gcCollect();
}

fn main() {
  mut n = 0;

  while n < *gc(5) {
    collect();
    n = n + 1;
    // CHECK: alloc @{{.*}}, data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: [0] mark @{{.*}}, data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: [0] sweep {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: alloc @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [1] mark @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [1] sweep @{{.*}}, data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: [1] sweep {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: alloc @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [2] mark @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [2] sweep @{{.*}}, data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: [2] sweep {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: alloc @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [3] mark @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [3] sweep @{{.*}}, data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: [3] sweep {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: alloc @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [4] mark @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [4] sweep @{{.*}}, data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: [4] sweep {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: alloc @{{.*}}, data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
  }

  println(0);
  // CHECK-NEXT: 0
}