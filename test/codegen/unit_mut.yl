// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | ( ! grep ^ )
fn foo(mut x: unit) {
  x = x;
}
// CHECK: define void @foo(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn main() {
  foo(unit);
}
// CHECK: define void @__builtin_main(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @foo(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
