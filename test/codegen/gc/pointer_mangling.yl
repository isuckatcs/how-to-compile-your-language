// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %valgrind %t

// CHECK: @mn.offsets = internal constant { i32, i32, [1 x i32] } { i32 8, i32 1, [1 x i32] zeroinitializer }
// CHECK: @pn.offsets = internal constant { i32, i32, [1 x i32] } { i32 8, i32 1, [1 x i32] zeroinitializer }

fn foo<T>(t: T) {}

fn bar<T>(t: *T) {}

fn barM<T>(t: *mut T) {}

fn main() {
  foo(gc(0));
  // CHECK: call void @_Y3fooGpnE(ptr %0, ptr null)
  bar(gc(gcMut(0)));
  // CHECK: call void @_Y3barGmnE(ptr %2, ptr null)

  foo(gcMut(0));
  // CHECK: call void @_Y3fooGmnE(ptr %3, ptr null)
  barM(gcMut(gc(0)));
  // CHECK: call void @_Y4barMGpnE(ptr %5, ptr null)
}
