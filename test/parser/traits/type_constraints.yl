// RUN: compiler %s -ast-dump 2>&1 | filecheck %s
trait A : B & C & D {}
// CHECK: TraitDecl: A
// CHECK-NEXT:   TraitInstance: B
// CHECK-NEXT:   TraitInstance: C
// CHECK-NEXT:   TraitInstance: D

fn foo<T : B & C & D>() {}
// CHECK: FunctionDecl: foo
// CHECK-NEXT:   TypeParamDecl: T
// CHECK-NEXT:     TraitInstance: B
// CHECK-NEXT:     TraitInstance: C
// CHECK-NEXT:     TraitInstance: D
// CHECK-NEXT:   Block

fn main() {}
