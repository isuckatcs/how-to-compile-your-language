// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
struct S { s2: *S2 }
struct S2 { s3: *S3 }
struct S3 { n: *number }

fn foo(): *S {
  let n = gc(123);
  let s3 = gc(S3{ n: n });
  let s2 = gc(S2{ s3: s3 });
  let s = gc(S{ s2: s2 });
  return s;
}

fn main() {
  let s = foo();

  println(*s.s2.s3.n);
  // CHECK: 123

  gcCollect();
  // CHECK-NEXT: [1] mark @{{.*}}, data: {{.*}} (8 B) offsets: {0 @{{.*}}} {heap: 128 B, threshold: 256 B} 
  // CHECK-NEXT: [1] mark @{{.*}}, data: {{.*}} (8 B) offsets: {0 @{{.*}}} {heap: 128 B, threshold: 256 B} 
  // CHECK-NEXT: [1] mark @{{.*}}, data: {{.*}} (8 B) offsets: {0 @{{.*}}} {heap: 128 B, threshold: 256 B} 
  // CHECK-NEXT: [1] mark @{{.*}}, data: {{.*}} (8 B) {heap: 128 B, threshold: 256 B} 
  // CHECK-NEXT: [1] sweep {heap: 128 B, threshold: 256 B}
}
