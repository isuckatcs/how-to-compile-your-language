// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '1\n2\n3\n456\n123\n123\n123\n'
fn main() {
  mut x = 123;

  let l1 = ->(x: number) { println(x); };
  let l2 = ->() { println(x); };

  x = 456;

  l1(1);
  l1(2);
  l1(3);

  println(x);

  l2();
  l2();
  l2();
}

// CHECK: define void @_YS8lambda_021__builtin_lambda_call(double %x, ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double %x)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YS8lambda_121__builtin_lambda_call(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %closure, i32 0, i32 0
// CHECK-NEXT:   %1 = load double, ptr %0, align 8
// CHECK-NEXT:   call void @println(double %1)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK-NOT: {{.*lambda_2.*}}
