// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
trait A<T> {
  fn foo(self: borrowed Self, x: T) {
    println(123);
  }
  // CHECK: define void @_YT1AGnE3fooGS1SE(ptr %self, double %x, ptr %closure) {
  // CHECK-NEXT: entry:
  // CHECK-NEXT:   call void @println(double 1.230000e+02, ptr null)
  // CHECK-NEXT:   ret void
  // CHECK-NEXT: }
}

struct S {
  x: number

  impl A<number>;
}

fn main() {
  let s = S{ x: 2 };
  s.foo(0);
}
