// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {}

fn foo<T>(x: borrowed T) {}
// CHECK: FunctionDecl @({{.*}}) foo {(borrowed T) -> unit}
// CHECK-NEXT:   TypeParamDecl @({{.*}}) T
// CHECK-NEXT:   ParamDecl @({{.*}}) x {borrowed T}
// CHECK-NEXT:   Block

fn main() {
  mut n = 0;
  mut s = S {};

  foo(n);
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) foo {(borrowed number) -> unit}
  // CHECK-NEXT:   ImplicitBorrowExpr {borrowed number}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) n {number}

  foo(s);
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) foo {(borrowed S) -> unit}
  // CHECK-NEXT:   ImplicitBorrowExpr {borrowed S}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) s {S}
}
