// RUN: compiler %s -res-dump 2>&1 | filecheck %s
trait A<T <: Base<S>> {}
// CHECK: TraitDecl @({{.*}}) A
// CHECK-NEXT:   TypeParamDecl @({{.*}}) T {T}

trait B {}
// CHECK-NEXT: TraitDecl @({{.*}}) B

trait Base<T <: B> {}
// CHECK-NEXT: TraitDecl @({{.*}}) Base
// CHECK-NEXT:   TypeParamDecl @({{.*}}) T {T}

struct S {
    impl B;
}
// CHECK-NEXT: StructDecl @({{.*}}) S {S}

fn main() {}
