// RUN: compiler %s -o expressions && ./expressions | grep -Plzx '1\n-1\n-9\n'
fn foo(x: number): number {
    if x < (0.0 - 5.0) {
        return (0.0 - 1.0);
    } else if x > 5.0 {
        return 1.0;
    }

    let x: number = 2.0 + 3.0;
    
    let y: bool = x == 0;
    
    mut r: number;
    if !y {
        r = 1;
    } else {
        r = 0;
    }

    r = 3.0 * r / (1.5 + 1.5);

    return r - 10.0;
}

fn main(): unit {
    println(foo(6.0));
    println(foo(0.0 - 6.0));
    println(foo(1.0));
}
