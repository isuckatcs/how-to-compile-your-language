// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o negate_bool_value && ./negate_bool_value | grep -Plzx '123\n'
fn main() {
  mut b = false;

  let r = !b;
  // CHECK: %0 = load i8, ptr %b, align 1
  // CHECK-NEXT: %1 = trunc i8 %0 to i1
  // CHECK-NEXT: %2 = xor i1 %1, true
  // CHECK-NEXT: %3 = zext i1 %2 to i8
  // CHECK-NEXT: store i8 %3, ptr %r, align 1

  if r {
    println(123);
  }
}
