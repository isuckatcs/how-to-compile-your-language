// RUN: compiler %s 2>&1 -ast-dump | filecheck %s
fn main() {
  // CHECK: [[# @LINE + 1 ]]:3: error: expected expression
  &&x;

  // CHECK: [[# @LINE + 1 ]]:3: error: expected expression
  &&&x;

  // CHECK: [[# @LINE + 1 ]]:3: error: expected expression
  &&&&x;

  // CHECK: [[# @LINE + 1 ]]:3: error: expected expression
  &x;

  // CHECK: [[# @LINE + 1 ]]:3: error: expected expression
  &x && &x;
}
