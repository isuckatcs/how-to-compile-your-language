// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s

// CHECK: define void @gcCollect(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @gcMark()
// CHECK-NEXT:   call void @gcSweep()
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn main() {
  gc(unit);
  // CHECK: %0 = call ptr @gcAlloc(i32 0, ptr null)

  gcMut(unit);
  // CHECK: %1 = call ptr @gcAlloc(i32 0, ptr null)
  
  gcCollect();
  // CHECK: call void @gcCollect(ptr null)
}

// CHECK: declare void @gcMark()

// CHECK: declare void @gcSweep()

// CHECK: declare ptr @gcAlloc(i32, ptr)
