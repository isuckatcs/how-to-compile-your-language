// RUN: compiler %s 2>&1 -res-dump | filecheck %s
trait A {}

trait B : A {}

trait C {}

fn foo(x: *impl B): *impl C {
  // CHECK: [[# @LINE + 1 ]]:10: error: cannot return '*impl B' from a function returning '*impl C'
  return x;
}

fn bar(x: *impl A): *impl B {
  // CHECK: [[# @LINE + 1 ]]:10: error: cannot return '*impl A' from a function returning '*impl B'
  return x;
}

fn main() {}
