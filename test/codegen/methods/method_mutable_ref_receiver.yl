// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '6\n3\n'
struct S {
  x: number

  fn foo(self: borrowed mut Self): Self {
    self.x = 3;
    return self;
  }
  // CHECK: define void @_YS1S3foo(ptr sret({ double }) %ret, ptr %self, ptr %closure) {
  // CHECK-NEXT: entry:
  // CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
  // CHECK-NEXT:   store double 3.000000e+00, ptr %0, align 8
  // CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 8 %ret, ptr align 8 %self, i64 8, i1 false)
  // CHECK-NEXT:   br label %return
  // CHECK-NEXT: 
  // CHECK-NEXT: return:                                           ; preds = %entry
  // CHECK-NEXT:   ret void
  // CHECK-NEXT: }

  fn bar(self: borrowed mut Self) {
    self.x = self.x * 2;
    println(self.x);
  }
  // CHECK: define void @_YS1S3bar(ptr %self, ptr %closure) {
  // CHECK-NEXT: entry:
  // CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
  // CHECK-NEXT:   %1 = load double, ptr %0, align 8
  // CHECK-NEXT:   %2 = fmul double %1, 2.000000e+00
  // CHECK-NEXT:   %3 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
  // CHECK-NEXT:   store double %2, ptr %3, align 8
  // CHECK-NEXT:   %4 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
  // CHECK-NEXT:   %5 = load double, ptr %4, align 8
  // CHECK-NEXT:   call void @println(double %5, ptr null)
  // CHECK-NEXT:   ret void
  // CHECK-NEXT: }
}

fn main() {
  mut s = S{ x: 123 };

  mut ret = s.foo().bar();
  // CHECK: call void @_YS1S3foo(ptr sret({ double }) %struct.ret.tmp, ptr %s, ptr null)
  // CHECK-NEXT: call void @_YS1S3bar(ptr %struct.ret.tmp, ptr null)

  println(s.x);
}
