// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
fn getGenerator(): () -> number {
  let x = gc(123);
  // CHECK: [0] alloc {{.*}} data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}

  return ->() { return *x; };
  // CHECK-NEXT: [0] alloc {{.*}} data: {{.*}} (8 B) offsets: {0 (nil)} {heap: 64 B, threshold: 96 B}
}

fn main() {
  let generator = getGenerator();

  gcCollect();
  // CHECK-NEXT: [0] mark {{.*}} data: {{.*}} (8 B) offsets: {0 {{.*}}} {heap: 64 B, threshold: 96 B}
  // CHECK-NEXT: [0] mark {{.*}} data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {heap: 64 B, threshold: 128 B}

  println(generator());
  // CHECK-NEXT: 123
}
// CHECK-NEXT: [1] sweep {{.*}} data: {{.*}} (8 B) offsets: {0 {{.*}}} {heap: 32 B, threshold: 128 B}
// CHECK-NEXT: [1] sweep {{.*}} data: {{.*}} (8 B) {heap: 0 B, threshold: 128 B}
// CHECK-NEXT: [1] sweep {heap: 0 B, threshold: 96 B}
