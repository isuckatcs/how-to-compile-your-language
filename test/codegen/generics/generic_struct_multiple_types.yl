// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '1\n1\n2\n2\n3\n3\n'

struct S<T> {
  x: T
}

fn returnOne(): number {
  return 1;
}

fn main(): unit {
  println(S{x: returnOne}.x());
  println(S{x: returnOne}.x());
  // CHECK: %12 = getelementptr inbounds nuw { { ptr, ptr } }, ptr %S.tmp1, i32 0, i32 0
  // CHECK-NEXT: %13 = getelementptr inbounds nuw { ptr, ptr }, ptr %12, i32 0, i32 0
  // CHECK-NEXT: %14 = load ptr, ptr %13, align 8
  // CHECK-NEXT: %15 = getelementptr inbounds nuw { ptr, ptr }, ptr %12, i32 0, i32 1
  // CHECK-NEXT: %16 = load ptr, ptr %15, align 8
  // CHECK-NEXT: %17 = call double %14(ptr %16)
  // CHECK-NEXT: call void @println(double %17)

  println(S{x: 2}.x);
  println(S{x: 2}.x);
  // CHECK: %22 = getelementptr inbounds nuw { double }, ptr %S.tmp3, i32 0, i32 0
  // CHECK-NEXT: %23 = load double, ptr %22, align 8
  // CHECK-NEXT: call void @println(double %23)

  println(S{x: S{x: 3}}.x.x);
  println(S{x: S{x: 3}}.x.x);
  // CHECK: %31 = getelementptr inbounds nuw { { double } }, ptr %S.tmp7, i32 0, i32 0
  // CHECK-NEXT: %32 = getelementptr inbounds nuw { double }, ptr %31, i32 0, i32 0
  // CHECK-NEXT: %33 = load double, ptr %32, align 8
  // CHECK-NEXT: call void @println(double %33)
}
