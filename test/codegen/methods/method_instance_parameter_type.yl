// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o method_instance_parameter_type && ./method_instance_parameter_type | grep -Plzx '123\n'
struct S<T> {
  fn foo(self: Self, x: S<number>, y: S<unit>) {
    println(123);
  }
}

fn main() {
  let s = S@<S<number>>{};
  s.foo(S{}, S{});
}
// CHECK: define void @__builtin_main() {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YS1SGS1SGnEE3foo()
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YS1SGS1SGnEE3foo() {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double 1.230000e+02)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
