// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {
  fn create(): Self {
    return S{};
  }
}
// CHECK: StructDecl @({{.*}}) S {S}
// CHECK-NEXT:   FunctionDecl @({{.*}}) create {() -> S}
// CHECK-NEXT:     Block
// CHECK-NEXT:       ReturnStmt
// CHECK-NEXT:         StructInstantiationExpr {S}
// CHECK-NEXT:           DeclRefExpr @({{.*}}) S {S}

fn main() {
  let s = S::create();
}
// CHECK: FunctionDecl @({{.*}}) main {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     DeclStmt
// CHECK-NEXT:       VarDecl @({{.*}}) s {S}
// CHECK-NEXT:         CallExpr {S}
// CHECK-NEXT:           DeclRefExpr @({{.*}}) S::create {() -> S}
