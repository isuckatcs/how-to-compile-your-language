// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {
  fn classMethod() {}
  // CHECK: FunctionDecl @({{.*}}) classMethod {() -> unit}
  // CHECK-NEXT:   Block

  fn instanceMethod(self: borrowed Self, x: number) {}
  // CHECK: FunctionDecl @({{.*}}) instanceMethod {(borrowed S, number) -> unit}
  // CHECK-NEXT:   ParamDecl @({{.*}}) self {borrowed S}
  // CHECK-NEXT:   ParamDecl @({{.*}}) x {number}
  // CHECK-NEXT:   Block
}

fn main() {
  let classLevel = S::classMethod;
  // CHECK: DeclStmt
  // CHECK-NEXT:   VarDecl @({{.*}}) classLevel {() -> unit}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) S::classMethod {() -> unit}
  
  classLevel();
  // CHECK-NEXT: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) classLevel {() -> unit}
  
  let instanceLevel = S::instanceMethod;
  // CHECK: DeclStmt
  // CHECK-NEXT:   VarDecl @({{.*}}) instanceLevel {(borrowed S, number) -> unit}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) S::instanceMethod {(borrowed S, number) -> unit}
  
  let s = S{};
  instanceLevel(s, 0);
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) instanceLevel {(borrowed S, number) -> unit}
  // CHECK-NEXT:   ImplicitBorrowExpr {borrowed S}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) s {S}
  // CHECK-NEXT:   NumberLiteral '0' {number}
  // CHECK-NEXT:   | value: 0
}
