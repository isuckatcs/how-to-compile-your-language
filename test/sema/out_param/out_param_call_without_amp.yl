// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn bar(x: borrowed mut number) {
  x = 1;
}

fn main() {
  mut x = 0;

  bar(x);
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) bar {(&mut number) -> unit}
  // CHECK-NEXT:   ImplicitBorrowExpr {&mut number}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) x {number}
}
