// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn main() {
  let x = 0;

  ->() {
    ->() {
      println(x);
    };
  };
  // CHECK: LambdaExpr {(lambda@<source>:5:3)}
  // CHECK-NEXT:   StructDecl @({{.*}}) (lambda@<source>:5:3) {(lambda@<source>:5:3)}
  // CHECK-NEXT:     FunctionDecl @({{.*}}) __builtin_lambda_call {((lambda@<source>:5:3)) -> unit}
  // CHECK-NEXT:       ParamDecl @({{.*}}) self {(lambda@<source>:5:3)}
  // CHECK-NEXT:       Block
  // CHECK-NEXT:         LambdaExpr {(lambda@<source>:6:5)}
  // CHECK-NEXT:           StructDecl @({{.*}}) (lambda@<source>:6:5) {(lambda@<source>:6:5)}
  // CHECK-NEXT:             FunctionDecl @({{.*}}) __builtin_lambda_call {((lambda@<source>:6:5)) -> unit}
  // CHECK-NEXT:               ParamDecl @({{.*}}) self {(lambda@<source>:6:5)}
  // CHECK-NEXT:               Block
  // CHECK-NEXT:                 CallExpr {unit}
  // CHECK-NEXT:                   PathExpr {(number) -> unit}
  // CHECK-NEXT:                     DeclRefExpr @({{.*}}) println {(number) -> unit}
  // CHECK-NEXT:                   MemberExpr @({{.*}}) x {number}
  // CHECK-NEXT:                     PathExpr {(lambda@<source>:6:5)}
  // CHECK-NEXT:                       DeclRefExpr @({{.*}}) self {(lambda@<source>:6:5)}
  // CHECK-NEXT:             FieldDecl @({{.*}}) x {number}
  // CHECK-NEXT:           MemberExpr @({{.*}}) x {number}
  // CHECK-NEXT:             PathExpr {(lambda@<source>:5:3)}
  // CHECK-NEXT:               DeclRefExpr @({{.*}}) self {(lambda@<source>:5:3)}
  // CHECK-NEXT:     FieldDecl @({{.*}}) x {number}
  // CHECK-NEXT:   PathExpr {number}
  // CHECK-NEXT:   | value: 0
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) x {number}
}

