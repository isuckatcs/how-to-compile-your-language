// RUN: compiler %s -cfg-dump 2>&1 | filecheck %s --match-full-lines
struct S<T> {
  fn foo<U>() {}
}

trait A {
  fn foo() {}
}

struct S2 {
  impl A;
}

fn main() {
  S@<number>::foo@<number>();

  S2::impl A::foo();
}
// CHECK: main:
// CHECK-NEXT: [2 (entry)]
// CHECK-NEXT:   preds: 
// CHECK-NEXT:   succs: 1 
// CHECK-NEXT: 
// CHECK-NEXT: [1]
// CHECK-NEXT:   preds: 2 
// CHECK-NEXT:   succs: 0 
// CHECK-NEXT:   1: S
// CHECK-NEXT:   2: [1.1]::foo
// CHECK-NEXT:   3: [1.2]()
// CHECK-NEXT:   4: S2
// CHECK-NEXT:   5: [1.4]::impl A::foo
// CHECK-NEXT:   6: [1.5]()
// CHECK-NEXT: 
// CHECK-NEXT: [0 (exit)]
// CHECK-NEXT:   preds: 1 
// CHECK-NEXT:   succs: 
