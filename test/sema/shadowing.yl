// RUN: compiler %s -res-dump 2>&1 | filecheck %s --implicit-check-not error
// CHECK: {{.*}}
fn foo(x: number): unit {
    let x: number = 1.0;

    if false {
        let x: number = 2.0;

        if false {
            let x: number = 3.0;
        }
    } else {
        let x: number = 4.0;
    }

    while false {
        let x: number = 5.0;

        if false {
            let x: number = 6.0;

            if false {
                let x: number = 7.0;
            }
        } else {
            let x: number = 8.0;
        }
    }
}

fn main(): unit {
    foo(0.0);
}
