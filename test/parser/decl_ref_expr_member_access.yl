// RUN: compiler %s 2>&1 -ast-dump | filecheck %s
fn main() {
  S@<number>::create();
  // CHECK: CallExpr:
  // CHECK-NEXT:   PathExpr:
  // CHECK-NEXT:     DeclRefExpr: S
  // CHECK-NEXT:       TypeArgumentList
  // CHECK-NEXT:         BuiltinType: number
  // CHECK-NEXT:     DeclRefExpr: create

  S@<number>::foo@<number>();
  // CHECK: CallExpr:
  // CHECK-NEXT:   PathExpr:
  // CHECK-NEXT:     DeclRefExpr: S
  // CHECK-NEXT:       TypeArgumentList
  // CHECK-NEXT:         BuiltinType: number
  // CHECK-NEXT:     DeclRefExpr: foo
  // CHECK-NEXT:       TypeArgumentList
  // CHECK-NEXT:         BuiltinType: number

  Self::create();
  // CHECK: CallExpr:
  // CHECK-NEXT:   PathExpr:
  // CHECK-NEXT:     DeclRefExpr: Self
  // CHECK-NEXT:     DeclRefExpr: create

  Self{};
  // CHECK: StructInstantiationExpr
  // CHECK-NEXT:   PathExpr:
  // CHECK-NEXT:     DeclRefExpr: Self
}
