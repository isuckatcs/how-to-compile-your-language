// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n456\n123\n123\n'
struct N {
  n: number
}

struct F {
  f: (N) -> N,
}

fn foo(mut n: N): N {
  n.n = 456;
  return n;
}
// CHECK: define void @foo(ptr sret({ double }) %ret, ptr byval({ double }) %n, ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %n, i32 0, i32 0
// CHECK-NEXT:   store double 4.560000e+02, ptr %0, align 8
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 8 %ret, ptr align 8 %n, i64 8, i1 false)
// CHECK-NEXT:   br label %return
// CHECK-NEXT: 
// CHECK-NEXT: return:                                           ; preds = %entry
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn bar(n: N): N {
  return n;
}
// CHECK: define void @bar(ptr sret({ double }) %ret, ptr byval({ double }) %n, ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 8 %ret, ptr align 8 %n, i64 8, i1 false)
// CHECK-NEXT:   br label %return
// CHECK-NEXT: 
// CHECK-NEXT: return:                                           ; preds = %entry
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn main() {
  let n = N { n: 123 };
  let f = F { f: foo };
  let f2 = F { f: bar };

  println(n.n);

  println(f.f(n).n);
  // CHECK: %9 = getelementptr inbounds nuw { { ptr, ptr } }, ptr %f, i32 0, i32 0
  // CHECK-NEXT: call void @llvm.memcpy.p0.p0.i64(ptr align 8 %struct.arg.tmp, ptr align 8 %n, i64 8, i1 false)
  // CHECK-NEXT: %10 = getelementptr inbounds nuw { ptr, ptr }, ptr %9, i32 0, i32 0
  // CHECK-NEXT: %11 = load ptr, ptr %10, align 8
  // CHECK-NEXT: %12 = getelementptr inbounds nuw { ptr, ptr }, ptr %9, i32 0, i32 1
  // CHECK-NEXT: %13 = load ptr, ptr %12, align 8
  // CHECK-NEXT: call void %11(ptr sret({ double }) %struct.ret.tmp, ptr byval({ double }) %struct.arg.tmp, ptr %13)
  // CHECK-NEXT: %14 = getelementptr inbounds nuw { double }, ptr %struct.ret.tmp, i32 0, i32 0
  // CHECK-NEXT: %15 = load double, ptr %14, align 8
  // CHECK-NEXT: call void @println(double %15, ptr null)

  println(f2.f(n).n);
  // CHECK: %16 = getelementptr inbounds nuw { { ptr, ptr } }, ptr %f2, i32 0, i32 0
  // CHECK-NEXT: call void @llvm.memcpy.p0.p0.i64(ptr align 8 %struct.arg.tmp3, ptr align 8 %n, i64 8, i1 false)
  // CHECK-NEXT: %17 = getelementptr inbounds nuw { ptr, ptr }, ptr %16, i32 0, i32 0
  // CHECK-NEXT: %18 = load ptr, ptr %17, align 8
  // CHECK-NEXT: %19 = getelementptr inbounds nuw { ptr, ptr }, ptr %16, i32 0, i32 1
  // CHECK-NEXT: %20 = load ptr, ptr %19, align 8
  // CHECK-NEXT: call void %18(ptr sret({ double }) %struct.ret.tmp2, ptr byval({ double }) %struct.arg.tmp3, ptr %20)
  // CHECK-NEXT: %21 = getelementptr inbounds nuw { double }, ptr %struct.ret.tmp2, i32 0, i32 0
  // CHECK-NEXT: %22 = load double, ptr %21, align 8
  // CHECK-NEXT: call void @println(double %22, ptr null)

  println(n.n);
}
