// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
fn main() {
  let x = 123;

  ->() {
    ->() {
      println(x);
    }();
  }();
  // CHECK: %lambda.tmp = alloca { ptr, ptr }, align 8
  // CHECK-NEXT: store { ptr, ptr } zeroinitializer, ptr %lambda.tmp, align 8
  // CHECK-NEXT: call void @llvm.gcroot(ptr %lambda.tmp, ptr @function.offsets)

  // CHECK-NEXT: %0 = call ptr @gcAlloc(i32 8, ptr null)
  // CHECK-NEXT: %1 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 0
  // CHECK-NEXT: store ptr @_YS8lambda_021__builtin_lambda_call, ptr %1, align 8
  // CHECK-NEXT: %2 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 1
  // CHECK-NEXT: store ptr %0, ptr %2, align 8

  // CHECK-NEXT: %3 = getelementptr inbounds nuw { double }, ptr %0, i32 0, i32 0
  // CHECK-NEXT: store double 1.230000e+02, ptr %3, align 8

  // CHECK-NEXT: %4 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 0
  // CHECK-NEXT: %5 = load ptr, ptr %4, align 8
  // CHECK-NEXT: %6 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 1
  // CHECK-NEXT: %7 = load ptr, ptr %6, align 8
  // CHECK-NEXT: call void %5(ptr %7)
}
// CHECK: define void @_YS8lambda_021__builtin_lambda_call(ptr %self) gc "shadow-stack" {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %lambda.tmp = alloca { ptr, ptr }, align 8
// CHECK-NEXT:   store { ptr, ptr } zeroinitializer, ptr %lambda.tmp, align 8
// CHECK-NEXT:   call void @llvm.gcroot(ptr %lambda.tmp, ptr @function.offsets)

// CHECK-NEXT:   %0 = call ptr @gcAlloc(i32 8, ptr null)
// CHECK-NEXT:   %1 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 0
// CHECK-NEXT:   store ptr @_YS8lambda_121__builtin_lambda_call, ptr %1, align 8
// CHECK-NEXT:   %2 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 1
// CHECK-NEXT:   store ptr %0, ptr %2, align 8

// CHECK-NEXT:   %3 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
// CHECK-NEXT:   %4 = load double, ptr %3, align 8
// CHECK-NEXT:   %5 = getelementptr inbounds nuw { double }, ptr %0, i32 0, i32 0
// CHECK-NEXT:   store double %4, ptr %5, align 8

// CHECK-NEXT:   %6 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 0
// CHECK-NEXT:   %7 = load ptr, ptr %6, align 8
// CHECK-NEXT:   %8 = getelementptr inbounds nuw { ptr, ptr }, ptr %lambda.tmp, i32 0, i32 1
// CHECK-NEXT:   %9 = load ptr, ptr %8, align 8
// CHECK-NEXT:   call void %7(ptr %9)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YS8lambda_121__builtin_lambda_call(ptr %self) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
// CHECK-NEXT:   %1 = load double, ptr %0, align 8
// CHECK-NEXT:   call void @println(double %1)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
