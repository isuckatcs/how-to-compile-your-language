// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '246\n'

struct A<T> {
  x: T
}

struct B<T> {
  a: A<(T) -> T>
}

fn double(n: number): number {
  return n * 2;
}

fn main(): unit {
  let b = B{a: A{x: double}};

  println(b.a.x(123));
  // CHECK: %4 = getelementptr inbounds nuw { { { ptr, ptr } } }, ptr %b, i32 0, i32 0
  // CHECK-NEXT: %5 = getelementptr inbounds nuw { { ptr, ptr } }, ptr %4, i32 0, i32 0
  // CHECK-NEXT: %6 = getelementptr inbounds nuw { ptr, ptr }, ptr %5, i32 0, i32 0
  // CHECK-NEXT: %7 = load ptr, ptr %6, align 8
  // CHECK-NEXT: %8 = getelementptr inbounds nuw { ptr, ptr }, ptr %5, i32 0, i32 1
  // CHECK-NEXT: %9 = load ptr, ptr %8, align 8
  // CHECK-NEXT: %10 = call double %7(double 1.230000e+02, ptr %9)
  // CHECK-NEXT: call void @println(double %10)
}
