// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
trait A<T> {
  fn foo(self: borrowed Self);
}

struct S<T> {
  impl A<T> {
    fn foo(self: borrowed Self) {
      println(123);
    }
  }
}

fn main() {
  let s = S@<number>{};
  s.foo();
}
// CHECK: define void @__builtin_main(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %s = alloca {}, align 8
// CHECK-NEXT:   call void @_YT1AGnE3fooGS1SGnEE(ptr %s, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
