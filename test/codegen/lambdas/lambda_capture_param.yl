// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o lambda_capture_param && ./lambda_capture_param | grep -Plzx '5\n'
fn foo(x: number, mut y: number) {
  ->(){ println(x + y); }();
  // CHECK: %0 = load double, ptr %y1, align 8
  // CHECK-NEXT: %1 = getelementptr inbounds nuw { double, double }, ptr %closure.tmp, i32 0, i32 0
  // CHECK-NEXT: store double %x, ptr %1, align 8
  // CHECK-NEXT: %2 = getelementptr inbounds nuw { double, double }, ptr %closure.tmp, i32 0, i32 1
  // CHECK-NEXT: store double %0, ptr %2, align 8
}

fn main() {
  foo(2, 3);
}
