// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {
  fn foo(x: number) {}
}

fn main() {
  let f = ->(x) {
    let f = S::foo;
    f(x);
  };
  // CHECK: LambdaExpr {(lambda@<source>:7:11)}
  // CHECK-NEXT:   StructDecl @({{.*}}) (lambda@<source>:7:11) {(lambda@<source>:7:11)}
  // CHECK-NEXT:     FunctionDecl @({{.*}}) __builtin_lambda_call {((lambda@<source>:7:11), number) -> unit}
  // CHECK-NEXT:       ParamDecl @({{.*}}) self {(lambda@<source>:7:11)}
  // CHECK-NEXT:       ParamDecl @({{.*}}) x {number}
  // CHECK-NEXT:       Block
  // CHECK-NEXT:         DeclStmt
  // CHECK-NEXT:           VarDecl @({{.*}}) f {(number) -> unit}
  // CHECK-NEXT:             DeclRefExpr @({{.*}}) S::foo {(number) -> unit}
  // CHECK-NEXT:         CallExpr {unit}
  // CHECK-NEXT:           DeclRefExpr @({{.*}}) f {(number) -> unit}
  // CHECK-NEXT:           DeclRefExpr @({{.*}}) x {number}

  0;
  // CHECK-NEXT: NumberLiteral '0' {number}
}
