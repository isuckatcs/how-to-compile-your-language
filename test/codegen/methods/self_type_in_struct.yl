// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o self_type_in_struct && ./self_type_in_struct | grep -Plzx '0\n1\n0\n'
fn foo<T>(t: T) {
  println(1);
}

struct S {
  x: number,

  fn create(): Self {
    println(0);
    return Self{ x : 1 };
  }
  // CHECK: define void @_YS1S6create(ptr sret({ double }) %ret) {
  // CHECK-NEXT: entry:
  // CHECK-NEXT:   %S.tmp = alloca { double }, align 8
  // CHECK-NEXT:   call void @println(double 0.000000e+00)
  // CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %S.tmp, i32 0, i32 0
  // CHECK-NEXT:   store double 1.000000e+00, ptr %0, align 8
  // CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 8 %ret, ptr align 8 %S.tmp, i64 8, i1 false)
  // CHECK-NEXT:   br label %return
  // CHECK-NEXT: 
  // CHECK-NEXT: return:                                           ; preds = %entry
  // CHECK-NEXT:   ret void
  // CHECK-NEXT: }

  fn foo(self: Self) {
    foo@<Self>(self);
    Self::create();
  }
  // CHECK: define void @_YS1S3foo(ptr byval({ double }) %self) {
  // CHECK-NEXT: entry:
  // CHECK-NEXT:   %struct.arg.tmp = alloca { double }, align 8
  // CHECK-NEXT:   %struct.ret.tmp = alloca { double }, align 8
  // CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 8 %struct.arg.tmp, ptr align 8 %self, i64 8, i1 false)
  // CHECK-NEXT:   call void @_Y3fooGS1SE(ptr byval({ double }) %struct.arg.tmp)
  // CHECK-NEXT:   call void @_YS1S6create(ptr sret({ double }) %struct.ret.tmp)
  // CHECK-NEXT:   ret void
  // CHECK-NEXT: }
}

fn main() {
  S::create().foo();
}
// CHECK: define void @__builtin_main() {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %struct.ret.tmp = alloca { double }, align 8
// CHECK-NEXT:   %struct.arg.tmp = alloca { double }, align 8
// CHECK-NEXT:   call void @_YS1S6create(ptr sret({ double }) %struct.ret.tmp)
// CHECK-NEXT:   call void @llvm.memcpy.p0.p0.i64(ptr align 8 %struct.arg.tmp, ptr align 8 %struct.ret.tmp, i64 8, i1 false)
// CHECK-NEXT:   call void @_YS1S3foo(ptr byval({ double }) %struct.arg.tmp)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
