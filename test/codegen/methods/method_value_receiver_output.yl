// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o method_value_receiver_output && ./method_value_receiver_output | grep -Plzx '123\n6\n7\n'
struct S {
  x:number

  fn foo(self: &Self) {
    self.x = 3;

    self.bar();
  }
  // CHECK: define void @_YS1S3foo(ptr %self) {
  // CHECK-NEXT: entry:
  // CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
  // CHECK-NEXT:   store double 3.000000e+00, ptr %0, align 8
  // CHECK-NEXT:   call void @_YS1S3bar(ptr %self)
  // CHECK-NEXT:   ret void
  // CHECK-NEXT: }

  fn bar(self: &S) {
    self.x = self.x * 2;
    println(self.x);
  }
  // CHECK: define void @_YS1S3bar(ptr %self) {
  // CHECK-NEXT: entry:
  // CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
  // CHECK-NEXT:   %1 = load double, ptr %0, align 8
  // CHECK-NEXT:   %2 = fmul double %1, 2.000000e+00
  // CHECK-NEXT:   %3 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
  // CHECK-NEXT:   store double %2, ptr %3, align 8
  // CHECK-NEXT:   %4 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
  // CHECK-NEXT:   %5 = load double, ptr %4, align 8
  // CHECK-NEXT:   call void @println(double %5)
  // CHECK-NEXT:   ret void
  // CHECK-NEXT: }
}

fn main() {
  mut s = S{ x: 123 };

  println(s.x);

  s.foo();
  // CHECK: call void @_YS1S3foo(ptr %s)

  println(s.x + 1);
}
