// CHECK-NEXT:   Block

// CHECK-NEXT: FunctionDecl @({{.*}}) gcMut {(T) -> *mut T}
// CHECK-NEXT:   TypeParamDecl @({{.*}}) T {T}
// CHECK-NEXT:   ParamDecl @({{.*}}) t {T}
// CHECK-NEXT:   Block

// CHECK-NEXT: FunctionDecl @({{.*}}) gcCollect {() -> unit}
// CHECK-NEXT:   Block
