// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
struct S<T> {
  fn foo(self: Self, x: T, y: number) {
    println(y);
  }
}

fn main() {
  let x = S::foo;
  // CHECK: %0 = getelementptr inbounds nuw { ptr, ptr }, ptr %x, i32 0, i32 0
  // CHECK-NEXT: store ptr @_YS1SGnE3foo, ptr %0, align 8
  // CHECK-NEXT: %1 = getelementptr inbounds nuw { ptr, ptr }, ptr %x, i32 0, i32 1
  // CHECK-NEXT: store ptr null, ptr %1, align 8

  x(S{}, 123, 123);
  // CHECK-NEXT: %2 = getelementptr inbounds nuw { ptr, ptr }, ptr %x, i32 0, i32 0
  // CHECK-NEXT: %3 = load ptr, ptr %2, align 8
  // CHECK-NEXT: %4 = getelementptr inbounds nuw { ptr, ptr }, ptr %x, i32 0, i32 1
  // CHECK-NEXT: %5 = load ptr, ptr %4, align 8
  // CHECK-NEXT: call void %3(double 1.230000e+02, double 1.230000e+02, ptr %5)
}
