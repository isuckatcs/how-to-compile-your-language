// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {
  fn foo() {}
}
// CHECK: StructDecl @({{.*}}) S {S}
// CHECK-NEXT:   FunctionDecl @({{.*}}) foo {() -> unit}
// CHECK-NEXT:     Block

fn S(x: number) {}
// CHECK: FunctionDecl @({{.*}}) S {(number) -> unit}
// CHECK-NEXT:   ParamDecl @({{.*}}) x {number}
// CHECK-NEXT:   Block

fn main() {
  S::foo();
}
// CHECK: FunctionDecl @({{.*}}) main {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {() -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) S {S}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {() -> unit
