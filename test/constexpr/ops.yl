// RUN: compiler %s -res-dump 2>&1 | filecheck %s --match-full-lines
fn foo(n: number): unit {}

fn bar(b: bool): unit {}

fn prefix(x: number, y: bool): unit {
    bar(!true);
    bar(!false);
    bar(!y);
    foo(-x);
    foo(-1.23);
}
// CHECK: FunctionDecl @({{.*}}) prefix {(number, bool) -> unit}
// CHECK-NEXT:   ParamDecl @({{.*}}) x {number}
// CHECK-NEXT:   ParamDecl @({{.*}}) y {bool}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       UnaryOperator '!' {bool}
// CHECK-NEXT:       | value: 0
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       UnaryOperator '!' {bool}
// CHECK-NEXT:       | value: 1
// CHECK-NEXT:         BoolLiteral '0' {bool}
// CHECK-NEXT:         | value: 0
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       UnaryOperator '!' {bool}
// CHECK-NEXT:         PathExpr {bool}
// CHECK-NEXT:           DeclRefExpr @({{.*}}) y {bool}
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(number) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {(number) -> unit}
// CHECK-NEXT:       UnaryOperator '-' {number}
// CHECK-NEXT:         PathExpr {number}
// CHECK-NEXT:           DeclRefExpr @({{.*}}) x {number}
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(number) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {(number) -> unit}
// CHECK-NEXT:       UnaryOperator '-' {number}
// CHECK-NEXT:       | value: -1.23
// CHECK-NEXT:         NumberLiteral '1.23' {number}
// CHECK-NEXT:         | value: 1.23

fn multiplicative(x: number): unit {
    foo(5.0 * 3.0);
    foo(20.0 / 4.0);

    foo(x * 1.0);
    foo(1.0 * x);
}
// CHECK: FunctionDecl @({{.*}}) multiplicative {(number) -> unit}
// CHECK-NEXT:   ParamDecl @({{.*}}) x {number}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(number) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {(number) -> unit}
// CHECK-NEXT:       BinaryOperator '*' {number}
// CHECK-NEXT:       | value: 15
// CHECK-NEXT:         NumberLiteral '5' {number}
// CHECK-NEXT:         | value: 5
// CHECK-NEXT:         NumberLiteral '3' {number}
// CHECK-NEXT:         | value: 3
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(number) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {(number) -> unit}
// CHECK-NEXT:       BinaryOperator '/' {number}
// CHECK-NEXT:       | value: 5
// CHECK-NEXT:         NumberLiteral '20' {number}
// CHECK-NEXT:         | value: 20
// CHECK-NEXT:         NumberLiteral '4' {number}
// CHECK-NEXT:         | value: 4
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(number) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {(number) -> unit}
// CHECK-NEXT:       BinaryOperator '*' {number}
// CHECK-NEXT:         PathExpr {number}
// CHECK-NEXT:           DeclRefExpr @({{.*}}) x {number}
// CHECK-NEXT:         NumberLiteral '1' {number}
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(number) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {(number) -> unit}
// CHECK-NEXT:       BinaryOperator '*' {number}
// CHECK-NEXT:         NumberLiteral '1' {number}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:         PathExpr {number}
// CHECK-NEXT:           DeclRefExpr @({{.*}}) x {number}

fn additive(): unit {
    foo(5.0 + 3.0);
    foo(20.0 - 4.0);
}
// CHECK: FunctionDecl @({{.*}}) additive {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(number) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {(number) -> unit}
// CHECK-NEXT:       BinaryOperator '+' {number}
// CHECK-NEXT:       | value: 8
// CHECK-NEXT:         NumberLiteral '5' {number}
// CHECK-NEXT:         | value: 5
// CHECK-NEXT:         NumberLiteral '3' {number}
// CHECK-NEXT:         | value: 3
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(number) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {(number) -> unit}
// CHECK-NEXT:       BinaryOperator '-' {number}
// CHECK-NEXT:       | value: 16
// CHECK-NEXT:         NumberLiteral '20' {number}
// CHECK-NEXT:         | value: 20
// CHECK-NEXT:         NumberLiteral '4' {number}
// CHECK-NEXT:         | value: 4

fn comparison(): unit {
    bar(2.0 < 5.0);
    bar(5.0 < 2.0);

    bar(2.0 > 5.0);
    bar(5.0 > 2.0);
}
// CHECK: FunctionDecl @({{.*}}) comparison {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '<' {bool}
// CHECK-NEXT:       | value: 1
// CHECK-NEXT:         NumberLiteral '2' {number}
// CHECK-NEXT:         | value: 2
// CHECK-NEXT:         NumberLiteral '5' {number}
// CHECK-NEXT:         | value: 5
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '<' {bool}
// CHECK-NEXT:       | value: 0
// CHECK-NEXT:         NumberLiteral '5' {number}
// CHECK-NEXT:         | value: 5
// CHECK-NEXT:         NumberLiteral '2' {number}
// CHECK-NEXT:         | value: 2
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '>' {bool}
// CHECK-NEXT:       | value: 0
// CHECK-NEXT:         NumberLiteral '2' {number}
// CHECK-NEXT:         | value: 2
// CHECK-NEXT:         NumberLiteral '5' {number}
// CHECK-NEXT:         | value: 5
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '>' {bool}
// CHECK-NEXT:       | value: 1
// CHECK-NEXT:         NumberLiteral '5' {number}
// CHECK-NEXT:         | value: 5
// CHECK-NEXT:         NumberLiteral '2' {number}
// CHECK-NEXT:         | value: 2

fn equality(): unit {
    bar(2.0 == 2.0);
    bar(5.0 == 3.0);
}
// CHECK-NEXT: FunctionDecl @({{.*}}) equality {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '==' {bool}
// CHECK-NEXT:       | value: 1
// CHECK-NEXT:         NumberLiteral '2' {number}
// CHECK-NEXT:         | value: 2
// CHECK-NEXT:         NumberLiteral '2' {number}
// CHECK-NEXT:         | value: 2
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '==' {bool}
// CHECK-NEXT:       | value: 0
// CHECK-NEXT:         NumberLiteral '5' {number}
// CHECK-NEXT:         | value: 5
// CHECK-NEXT:         NumberLiteral '3' {number}
// CHECK-NEXT:         | value: 3

fn conjunction(): unit {
    bar(true && true);
    bar(false && true);
    bar(true && false);
    bar(false && false);
}
// CHECK: FunctionDecl @({{.*}}) conjunction {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '&&' {bool}
// CHECK-NEXT:       | value: 1
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '&&' {bool}
// CHECK-NEXT:       | value: 0
// CHECK-NEXT:         BoolLiteral '0' {bool}
// CHECK-NEXT:         | value: 0
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '&&' {bool}
// CHECK-NEXT:       | value: 0
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:         BoolLiteral '0' {bool}
// CHECK-NEXT:         | value: 0
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '&&' {bool}
// CHECK-NEXT:       | value: 0
// CHECK-NEXT:         BoolLiteral '0' {bool}
// CHECK-NEXT:         | value: 0
// CHECK-NEXT:         BoolLiteral '0' {bool}

fn disjunction(): unit {
    bar(true || false);
    bar(false ||  true);
    bar(true || true);
    bar(false ||  false);
}
// CHECK: FunctionDecl @({{.*}}) disjunction {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '||' {bool}
// CHECK-NEXT:       | value: 1
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:         BoolLiteral '0' {bool}
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '||' {bool}
// CHECK-NEXT:       | value: 1
// CHECK-NEXT:         BoolLiteral '0' {bool}
// CHECK-NEXT:         | value: 0
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '||' {bool}
// CHECK-NEXT:       | value: 1
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:         BoolLiteral '1' {bool}
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {(bool) -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) bar {(bool) -> unit}
// CHECK-NEXT:       BinaryOperator '||' {bool}
// CHECK-NEXT:       | value: 0
// CHECK-NEXT:         BoolLiteral '0' {bool}
// CHECK-NEXT:         | value: 0
// CHECK-NEXT:         BoolLiteral '0' {bool}
// CHECK-NEXT:         | value: 0

fn main(): unit {}
