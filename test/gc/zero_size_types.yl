// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
struct Empty {}

fn main() {
  mut e = gc(Empty{});
  // CHECK: [0] alloc {{.*}} data: {{.*}} (0 B) {heap: 24 B, threshold: 96 B}

  mut u = gc(unit);
  // CHECK-NEXT: [0] alloc {{.*}} data: {{.*}} (0 B) {heap: 48 B, threshold: 96 B}

  e = gc(Empty{});
  // CHECK-NEXT: [0] alloc {{.*}} data: {{.*}} (0 B) {heap: 72 B, threshold: 96 B}

  u = gc(unit);
  // CHECK-NEXT: [0] alloc {{.*}} data: {{.*}} (0 B) {heap: 96 B, threshold: 96 B}

  gcCollect();
  // CHECK-NEXT: [0] mark {{.*}} data: {{.*}} (0 B) {heap: 96 B, threshold: 96 B}
  // CHECK-NEXT: [0] mark {{.*}} data: {{.*}} (0 B) {heap: 96 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {{.*}} data: {{.*}} (0 B) {heap: 72 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {{.*}} data: {{.*}} (0 B) {heap: 48 B, threshold: 96 B}
  // CHECK-NEXT: [0] sweep {heap: 48 B, threshold: 96 B}
}