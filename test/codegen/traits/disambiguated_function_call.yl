// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n246\n'
trait A<T> {
  fn foo(self: &Self, x: T) {}
}

struct S {
  x: number

  impl A<number> {
    fn foo(self: &Self, x: number) {
      println(self.x * x);
    }
  }

  impl A<unit> {
    fn foo(self: &Self, x: unit) {
      println(self.x);
    }
  }
}

fn main() {
  let s = S{ x: 123 };

  @<S impl A<unit>>::foo(&s, unit);
  // CHECK: call void @_YT1AGuE3fooGS1SE(ptr %s, ptr null)

  @<S impl A<number>>::foo(&s, 2);
  // CHECK-NEXT: call void @_YT1AGnE3fooGS1SE(ptr %s, double 2.000000e+00, ptr null)
}

// CHECK: define void @_YT1AGuE3fooGS1SE(ptr %self, ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
// CHECK-NEXT:   %1 = load double, ptr %0, align 8
// CHECK-NEXT:   call void @println(double %1, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YT1AGnE3fooGS1SE(ptr %self, double %x, ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %0 = getelementptr inbounds nuw { double }, ptr %self, i32 0, i32 0
// CHECK-NEXT:   %1 = load double, ptr %0, align 8
// CHECK-NEXT:   %2 = fmul double %1, %x
// CHECK-NEXT:   call void @println(double %2, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
