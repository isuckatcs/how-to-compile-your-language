// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '0\n'
fn main() {
  mut b = false;
  mut n = 0;

  b == b;
  // CHECK: %0 = load i8, ptr %b, align 1
  // CHECK-NEXT: %1 = trunc i8 %0 to i1
  // CHECK-NEXT: %2 = load i8, ptr %b, align 1
  // CHECK-NEXT: %3 = trunc i8 %2 to i1
  // CHECK-NEXT: %4 = icmp eq i1 %1, %3

  n == n;
  // CHECK: %5 = load double, ptr %n, align 8
  // CHECK-NEXT: %6 = load double, ptr %n, align 8
  // CHECK-NEXT: %7 = fcmp oeq double %5, %6

  println(0);
}
