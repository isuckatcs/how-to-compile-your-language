// RUN: compiler %s 2>&1 -ast-dump | filecheck %s
fn foo(): S<number> {}
// CHECK: FunctionDecl: foo
// CHECK-NEXT:   UserDefinedDeclInstance: S
// CHECK-NEXT:     BuiltinType: number
// CHECK-NEXT:   Block

fn bar(): S<userDefined> {}
// CHECK-NEXT: FunctionDecl: bar
// CHECK-NEXT:   UserDefinedDeclInstance: S
// CHECK-NEXT:     UserDefinedDeclInstance: userDefined
// CHECK-NEXT:   Block

fn baz(): S<S<S<S<deep>>>> {}
// CHECK-NEXT: FunctionDecl: baz
// CHECK-NEXT:   UserDefinedDeclInstance: S
// CHECK-NEXT:     UserDefinedDeclInstance: S
// CHECK-NEXT:       UserDefinedDeclInstance: S
// CHECK-NEXT:         UserDefinedDeclInstance: S
// CHECK-NEXT:           UserDefinedDeclInstance: deep
// CHECK-NEXT:   Block

fn main(): unit {}
// CHECK-NEXT: FunctionDecl: main
// CHECK-NEXT:   BuiltinType: unit
// CHECK-NEXT:   Block

// CHECK-NOT: {{.*}}
