// RUN: compiler %s 2>&1 -ast-dump | filecheck %s

fn foo(): impl A {}
// CHECK: FunctionDecl: foo
// CHECK-NEXT:   ImplType
// CHECK-NEXT:     TraitInstance: A
// CHECK-NEXT:   Block

fn bar(): impl A<x, y> {}
// CHECK-NEXT: FunctionDecl: bar
// CHECK-NEXT:   ImplType
// CHECK-NEXT:     TraitInstance: A
// CHECK-NEXT:       UserDefinedType: x
// CHECK-NEXT:       UserDefinedType: y
// CHECK-NEXT:   Block

fn baz(): impl A<x, y, z> {}
// CHECK-NEXT: FunctionDecl: baz
// CHECK-NEXT:   ImplType
// CHECK-NEXT:     TraitInstance: A
// CHECK-NEXT:       UserDefinedType: x
// CHECK-NEXT:       UserDefinedType: y
// CHECK-NEXT:       UserDefinedType: z
// CHECK-NEXT:   Block

fn main() {}
