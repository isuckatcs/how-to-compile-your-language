// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn foo<T>() {}

struct S<T> {
  fn foo<U>() {
    foo@<T>();
  }
}

fn main() {
  S@<number>::foo@<unit>();
}
// CHECK: FunctionDecl @({{.*}}) main {() -> unit}
// CHECK-NEXT:   Block
// CHECK-NEXT:     CallExpr {unit}
// CHECK-NEXT:       PathExpr {() -> unit}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) S {S<number>}
// CHECK-NEXT:         DeclRefExpr @({{.*}}) foo {() -> unit}
