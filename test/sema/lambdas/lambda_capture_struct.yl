// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {
  x: number
  y: number
}

fn main() {
  let s = S{ x: 0, y: 1 };

  ->(){ return s.x + s.y; };
  // CHECK: LambdaExpr {() -> number}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) s {S}
  // CHECK-NEXT:   StructDecl @({{.*}}) (closure@<source>:10:3) {(closure@<source>:10:3)}
  // CHECK-NEXT:     FunctionDecl @({{.*}}) __builtin_lambda_call {(*(closure@<source>:10:3)) -> number}
}
