// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
fn foo(f: (number) -> unit) {
  f(123);
}

fn main() {
  let l = ->(x: number) { println(x); };
  // CHECK: call void @llvm.memcpy.p0.p0.i64(ptr align 8 %l, ptr align 8 %lambda.tmp, i64 16, i1 false)

  let f: (number) -> unit = l; 
  // CHECK-NEXT: call void @llvm.memcpy.p0.p0.i64(ptr align 8 %f, ptr align 8 %l, i64 16, i1 false)

  foo(l);
  // CHECK-NEXT: call void @llvm.memcpy.p0.p0.i64(ptr align 8 %struct.arg.tmp, ptr align 8 %l, i64 16, i1 false)
  // CHECK-NEXT: call void @foo(ptr byval({ ptr, ptr }) %struct.arg.tmp)
}

// CHECK: define void @_YS8lambda_021__builtin_lambda_call(double %x, ptr %closure) {
// CHECK-NOT: {{.*lambda_1.*}}
