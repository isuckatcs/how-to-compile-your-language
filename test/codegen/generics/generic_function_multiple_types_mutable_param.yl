// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o generic_function_multiple_types_mutable_param && ./generic_function_multiple_types_mutable_param | grep -Plzx '1\n2\n3\n'
struct S {
  x: number
}

fn wrapper<T>(mut x: T): T {
  return x;
}

fn returnOne(): number {
  return 1;
}

fn main(): unit {
// CHECK: define void @__builtin_main() gc "shadow-stack" {

  let x = wrapper(returnOne)();
  // CHECK: call void @_Y7wrapperGFRnE(ptr sret({ ptr, ptr }) %struct.ret.tmp, ptr byval({ ptr, ptr }) %struct.arg.tmp)

  let y = wrapper(2);
  // CHECK: %7 = call double @_Y7wrapperGnE(double 2.000000e+00)

  let z = wrapper(S{ x: 3 }).x;
  // CHECK: call void @_Y7wrapperGS1SE(ptr sret({ double }) %struct.ret.tmp1, ptr byval({ double }) %struct.arg.tmp2)

  println(x);
  println(y);
  println(z);
}

// CHECK: define void @_Y7wrapperGFRnE(ptr sret({ ptr, ptr }) %ret, ptr byval({ ptr, ptr }) %x) {
// CHECK: define double @_Y7wrapperGnE(double %x) {
// CHECK: define void @_Y7wrapperGS1SE(ptr sret({ double }) %ret, ptr byval({ double }) %x) {

// CHECK-NOT: {{define.*wrapper.*}}
