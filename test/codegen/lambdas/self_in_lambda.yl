// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n456\n'
trait A {
  fn bar() {
    println(123);
  }

  fn foo() {
    ->(){
      Self::bar();
    }();
  }
}

struct S {
  impl A;

  fn bar() {
    println(456);
  }

  fn foo() {
    ->(){
      Self::bar();
    }();
  }
}

fn main() {
  @<S impl A>::foo();
  S::foo();
}
// CHECK: define void @_YS8lambda_021__builtin_lambda_call(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YS1S3bar(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YS8lambda_121__builtin_lambda_call(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YT1A3barGS1SE(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
