// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
struct S {
  n: S2,
  u: unit

  fn print(self: borrowed Self) {
    println(*self.n.n);
  }

  fn printMut(self: borrowed mut Self) {
    println(*self.n.n * 2);
  }
}

struct S2 {
  n: *number
}

fn allocate(): S2 {
  return S2 { n: gc(123) };
}

fn collect() {
  println(0);
  gcCollect();
}

fn main() {
  S {
    n: allocate(), 
    // CHECK: [0] alloc {{.*}} data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}

    u: collect()
    // CHECK-NEXT: 0
    // CHECK-NEXT: [0] mark {{.*}} data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: [0] sweep {heap: 32 B, threshold: 96 B}
  }.print();
  // CHECK-NEXT: 123

  S {
    n: allocate(), 
    // CHECK-NEXT: [1] alloc {{.*}} data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
  
    u: collect()
    // CHECK-NEXT: 0
    // CHECK-NEXT: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 64 B, threshold: 96 B}
    // CHECK-NEXT: [1] sweep {{.*}} data: {{.*}} (8 B) {heap: 32 B, threshold: 96 B}
    // CHECK-NEXT: [1] sweep {heap: 32 B, threshold: 96 B}
  }.printMut();
  // CHECK-NEXT: 246
}
