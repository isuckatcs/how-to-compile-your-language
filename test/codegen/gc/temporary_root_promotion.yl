// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
struct S {
  p: *number
}

fn foo(n: number): S {
  return S{ p: gc(n) };
}

fn main() {
  // CHECK: %struct.ret.tmp = alloca { ptr }, align 8
  // CHECK-NEXT: store { ptr } zeroinitializer, ptr %struct.ret.tmp, align 8
  // CHECK-NEXT: call void @llvm.gcroot(ptr %struct.ret.tmp, ptr @S1S.offsets)

  println(*foo(123).p);
  // CHECK: call void @println(double %2, ptr null)
  // CHECK-NEXT: store { ptr } zeroinitializer, ptr %struct.ret.tmp, align 8
}
