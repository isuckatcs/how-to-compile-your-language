// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n'
trait A<T> {
  fn foo(self: borrowed Self);
}

struct S<T> {
  impl A<T> {
    fn foo(self: borrowed Self) {
      println(123);
    }
  }
}

fn foo<X, U : A<X>>(u: U) {
  u.foo();
}
// CHECK: define void @_Y3fooGnS1SGnEE(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   %u = alloca {}, align 8
// CHECK-NEXT:   call void @_YT1AGnE3fooGS1SGnEE(ptr %u, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

fn main() {
  let s = S@<number>{};
  foo(s);
}
