// RUN: compiler %s -verify -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '123\n456\n'
trait A {
  fn bar() {
    Self::foo();
  }

  fn foo() {
    println(123);
  }
}

struct S {
  impl A;
}

struct S2 {
  impl A {
    fn foo() {
      println(456);
    }
  }
}

fn traitFnDispatch<T : A>() {
  T::bar();
}

fn main() {
  traitFnDispatch@<S>();
  traitFnDispatch@<S2>();
}
// CHECK: define void @__builtin_main(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_Y15traitFnDispatchGS1SE(ptr null)
// CHECK-NEXT:   call void @_Y15traitFnDispatchGS2S2E(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_Y15traitFnDispatchGS1SE(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YT1A3barGS1SE(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_Y15traitFnDispatchGS2S2E(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YT1A3barGS2S2E(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YT1A3barGS1SE(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YT1A3fooGS1SE(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YT1A3barGS2S2E(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @_YT1A3fooGS2S2E(ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YT1A3fooGS1SE(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double 1.230000e+02, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }

// CHECK: define void @_YT1A3fooGS2S2E(ptr %closure) {
// CHECK-NEXT: entry:
// CHECK-NEXT:   call void @println(double 4.560000e+02, ptr null)
// CHECK-NEXT:   ret void
// CHECK-NEXT: }
