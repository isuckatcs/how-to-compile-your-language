// RUN: compiler %s 2>&1 -res-dump | filecheck %s
fn main() {
  mut f = ->(){};

  f = f;
  // CHECK: Assignment
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) f {() -> unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) f {() -> unit}

  f = ->(){};
  // CHECK: Assignment
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) f {() -> unit}
  // CHECK-NEXT:   LambdaExpr {() -> unit}
  // CHECK-NEXT:     StructDecl @({{.*}}) (closure@<source>:10:7) {(closure@<source>:10:7)}
}
