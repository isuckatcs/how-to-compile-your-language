// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o variable_coerce && ./variable_coerce | grep -Plzx '123\n'
fn main() {
  mut f: (number) -> number = ->(x){ return x; };
  // CHECK: store ptr @_YS8lambda_021__builtin_lambda_call, ptr %f, align 8

  f = ->(x){ return x; };
  // CHECK-NEXT: store ptr @_YS8lambda_121__builtin_lambda_call, ptr %f, align 8

  println(f(123));
  // CHECK-NEXT: %0 = load ptr, ptr %f, align 8
  // CHECK-NEXT: %1 = call double %0(double 1.230000e+02)
}
