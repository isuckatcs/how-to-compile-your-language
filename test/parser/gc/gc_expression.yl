// RUN: compiler %s 2>&1 -ast-dump | filecheck %s
fn main() {
  gc(1);
  // CHECK: GCExpr
  // CHECK-NEXT:   NumberLiteral: '1'

  gcMut(2);
  // CHECK: GCExpr mut
  // CHECK-NEXT:   NumberLiteral: '2'

  gc(gcMut(3));
  // CHECK: GCExpr
  // CHECK-NEXT:   GCExpr mut
  // CHECK-NEXT:     NumberLiteral: '3'
}
