// RUN: compiler %s -verify-only
// RUN: compiler %s -llvm-dump 2>&1 | filecheck %s
// RUN: compiler %s -o %t && %t | grep -Plzx '1\n2\n3\n4\n5\n6\n7\n'

fn one(): (unit, unit) -> (unit, unit) -> unit {
  println(1);
  return four;
}

fn two() {
  println(2);
}

fn three() {
  println(3);
}

fn four(x: unit, y: unit): (unit, unit) -> unit {
  println(4);
  return seven;
}

fn five() {
  println(5);
}

fn six() {
  println(6);
}

fn seven(x: unit, y: unit) {
  println(7);
}

fn main() {
  one()(two(), three())(five(), six());
  // CHECK: call void @one(ptr sret({ ptr, ptr }) %struct.ret.tmp, ptr null)
  // CHECK-NEXT: call void @two(ptr null)
  // CHECK-NEXT: call void @three(ptr null)
  // CHECK-NEXT: %0 = getelementptr inbounds nuw { ptr, ptr }, ptr %struct.ret.tmp, i32 0, i32 0
  // CHECK-NEXT: %1 = load ptr, ptr %0, align 8
  // CHECK-NEXT: %2 = getelementptr inbounds nuw { ptr, ptr }, ptr %struct.ret.tmp, i32 0, i32 1
  // CHECK-NEXT: %3 = load ptr, ptr %2, align 8
  // CHECK-NEXT: call void %1(ptr sret({ ptr, ptr }) %struct.ret.tmp1, ptr %3)
  // CHECK-NEXT: call void @five(ptr null)
  // CHECK-NEXT: call void @six(ptr null)
  // CHECK-NEXT: %4 = getelementptr inbounds nuw { ptr, ptr }, ptr %struct.ret.tmp1, i32 0, i32 0
  // CHECK-NEXT: %5 = load ptr, ptr %4, align 8
  // CHECK-NEXT: %6 = getelementptr inbounds nuw { ptr, ptr }, ptr %struct.ret.tmp1, i32 0, i32 1
  // CHECK-NEXT: %7 = load ptr, ptr %6, align 8
  // CHECK-NEXT: call void %5(ptr %7)
}
