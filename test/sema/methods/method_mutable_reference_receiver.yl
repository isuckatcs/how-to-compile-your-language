// RUN: compiler %s 2>&1 -res-dump | filecheck %s
struct S {
  x:number

  fn foo(self: borrowed mut Self) {
    self.x = 1;
  }

  fn bar(self: borrowed mut S) {
    self.x = 1;
  }
}
// CHECK: StructDecl @({{.*}}) S {S}
// CHECK-NEXT:   FieldDecl @({{.*}}) x {number}
// CHECK-NEXT:   FunctionDecl @({{.*}}) foo {(&mut S) -> unit}
// CHECK-NEXT:     ParamDecl @({{.*}}) self {&mut S}
// CHECK-NEXT:     Block
// CHECK-NEXT:       Assignment
// CHECK-NEXT:         MemberExpr @({{.*}}) x {number}
// CHECK-NEXT:           ImplicitDerefExpr {S}
// CHECK-NEXT:             DeclRefExpr @({{.*}}) self {&mut S}
// CHECK-NEXT:         NumberLiteral '1' {number}
// CHECK-NEXT:         | value: 1
// CHECK-NEXT:   FunctionDecl @({{.*}}) bar {(&mut S) -> unit}
// CHECK-NEXT:     ParamDecl @({{.*}}) self {&mut S}
// CHECK-NEXT:     Block
// CHECK-NEXT:       Assignment
// CHECK-NEXT:         MemberExpr @({{.*}}) x {number}
// CHECK-NEXT:           ImplicitDerefExpr {S}
// CHECK-NEXT:             DeclRefExpr @({{.*}}) self {&mut S}
// CHECK-NEXT:         NumberLiteral '1' {number}
// CHECK-NEXT:         | value: 1

fn main() {
  mut s = S{ x: 123 };

  s.foo();
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) S::foo {(&mut S) -> unit}
  // CHECK-NEXT:   ImplicitBorrowExpr {&mut S}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) s {S}

  s.bar();
  // CHECK: CallExpr {unit}
  // CHECK-NEXT:   DeclRefExpr @({{.*}}) S::bar {(&mut S) -> unit}
  // CHECK-NEXT:   ImplicitBorrowExpr {&mut S}
  // CHECK-NEXT:     DeclRefExpr @({{.*}}) s {S}
}
