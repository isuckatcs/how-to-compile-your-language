// RUN: compiler %s -o %t && YL_GC_DUMP=1 %t | filecheck %s
// RUN: %valgrind %t
struct R1 {
  x: number,
  y: *number,
  z: number,
}

struct R2 {
  x: number,
  y: *number,
  z: *number,
}

fn main() {
  let r1 = R1 {
    x: 0,
    y: gc(0),
    z: 0,
  };

  let r2 = R2 {
    x: 0,
    y: gc(0),
    z: gc(0),
  };

  let x = gc(0);

  let y = gc(0);

  gcCollect();
  // CHECK: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 160 B, threshold: 256 B}
  // CHECK-NEXT: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 160 B, threshold: 256 B}
  // CHECK-NEXT: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 160 B, threshold: 256 B}
  // CHECK-NEXT: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 160 B, threshold: 256 B}
  // CHECK-NEXT: [1] mark {{.*}} data: {{.*}} (8 B) {heap: 160 B, threshold: 256 B}
  // CHECK-NEXT: [1] sweep {heap: 160 B, threshold: 320 B}
}
