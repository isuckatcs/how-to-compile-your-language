// RUN: compiler %s 2>&1 -res-dump | filecheck %s
trait Foo {
  fn val(self: borrowed Self): Self;
  fn ptr(self: borrowed Self): *Self;
  fn ptrMut(self: borrowed Self): *mut Self;
}

struct S {
  impl Foo {
    fn val(self: borrowed Self): Self {
      return S{};
    }

    fn ptr(self: borrowed Self): *Self {
      return gc(S{});
    }

    fn ptrMut(self: borrowed Self): *mut Self {
      return gcMut(S{});
    }
  }
}

fn main() {
  mut x: *mut impl Foo = gcMut(S{});

  // CHECK: [[# @LINE + 1 ]]:5: error: methods with return type referecing 'Self' cannot be called with trait objects
  x.val();

  // CHECK: [[# @LINE + 1 ]]:5: error: methods with return type referecing 'Self' cannot be called with trait objects
  x.ptr();

  // CHECK: [[# @LINE + 1 ]]:5: error: methods with return type referecing 'Self' cannot be called with trait objects
  x.ptrMut();
}
